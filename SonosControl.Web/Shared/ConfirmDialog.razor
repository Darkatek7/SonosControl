@if (Visible)
{
    <AccessibleDialog Visible="true"
                      Title="@Title"
                      Eyebrow="Confirmation"
                      Role="alertdialog"
                      DescriptionId="@_messageId"
                      SizeClass="app-dialog--confirm"
                      OnClose="CancelAsync">
        <ChildContent>
            <p id="@_messageId" class="app-dialog__message">@Message</p>
        </ChildContent>
        <FooterContent>
            <button type="button" class="btn btn-outline-secondary" @onclick="CancelAsync">Cancel</button>
            <button type="button"
                    class="btn @(Dangerous ? "btn-danger" : "btn-primary")"
                    @onclick="ConfirmAsync">
                @ConfirmLabel
            </button>
        </FooterContent>
    </AccessibleDialog>
}

@code {
    private readonly string _messageId = $"confirm-message-{Guid.NewGuid():N}";

    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Confirm action";
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string ConfirmLabel { get; set; } = "Confirm";
    [Parameter] public bool Dangerous { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Task ConfirmAsync() => OnConfirm.InvokeAsync();
    private Task CancelAsync() => OnCancel.InvokeAsync();
}
