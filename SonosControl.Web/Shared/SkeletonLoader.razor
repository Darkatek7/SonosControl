@namespace SonosControl.Web.Shared

<div class="skeleton-loader @(Animated ? "animated" : "")" aria-busy="true" aria-label="Loading content">
    @for (int i = 0; i < Rows; i++)
    {
        <div class="skeleton-row">
            @if (ShowAvatar)
            {
                <div class="skeleton skeleton-avatar"></div>
            }
            @if (ShowText)
            {
                <div class="skeleton-content">
                    <div class="skeleton skeleton-text" style="width: @(i == Rows - 1 ? "60%" : "100%")"></div>
                    @if (ShowSubtext)
                    {
                        <div class="skeleton skeleton-subtext" style="width: @(i == Rows - 1 ? "40%" : "75%")"></div>
                    }
                </div>
            }
            @if (ShowBadge)
            {
                <div class="skeleton skeleton-badge"></div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int Rows { get; set; } = 3;

    [Parameter]
    public bool Animated { get; set; } = true;

    [Parameter]
    public bool ShowAvatar { get; set; } = false;

    [Parameter]
    public bool ShowText { get; set; } = true;

    [Parameter]
    public bool ShowSubtext { get; set; } = false;

    [Parameter]
    public bool ShowBadge { get; set; } = false;
}
