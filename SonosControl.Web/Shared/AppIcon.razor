@namespace SonosControl.Web.Shared

<svg class="@SvgClass"
     width="@Size"
     height="@Size"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="@StrokeWidth"
     stroke-linecap="round"
     stroke-linejoin="round"
     role="@(Decorative ? "presentation" : "img")"
     aria-hidden="@(Decorative ? "true" : "false")"
     aria-label="@AriaLabel">
    @switch (Name)
    {
        case "album":
            <rect x="3" y="4" width="18" height="16" rx="3"></rect>
            <circle cx="9" cy="10" r="1.5"></circle>
            <path d="M21 16l-5-5-7 7"></path>
            break;
        case "backups":
            <path d="M6 19h12"></path>
            <path d="M9 15h6"></path>
            <path d="M12 3v9"></path>
            <path d="M8 8l4 4 4-4"></path>
            <path d="M5 21h14"></path>
            break;
        case "calendar":
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <path d="M16 3v4"></path>
            <path d="M8 3v4"></path>
            <path d="M3 11h18"></path>
            break;
        case "cast":
            <path d="M4 18h.01"></path>
            <path d="M2 14a8 8 0 0 1 8 8"></path>
            <path d="M2 10a12 12 0 0 1 12 12"></path>
            <rect x="9" y="4" width="13" height="10" rx="2"></rect>
            break;
        case "chart":
            <path d="M4 19V5"></path>
            <path d="M20 19H4"></path>
            <path d="M8 15v-3"></path>
            <path d="M12 15V9"></path>
            <path d="M16 15V6"></path>
            break;
        case "clock":
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 3"></path>
            break;
        case "dashboard":
            <rect x="3" y="3" width="8" height="8" rx="2"></rect>
            <rect x="13" y="3" width="8" height="5" rx="2"></rect>
            <rect x="13" y="10" width="8" height="11" rx="2"></rect>
            <rect x="3" y="13" width="8" height="8" rx="2"></rect>
            break;
        case "devices":
            <rect x="3" y="5" width="7" height="14" rx="2"></rect>
            <rect x="14" y="8" width="7" height="8" rx="2"></rect>
            <path d="M6.5 9h.01"></path>
            <path d="M17.5 12h.01"></path>
            break;
        case "file":
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
            <path d="M14 3v5h5"></path>
            break;
        case "home":
            <path d="M3 10.5L12 3l9 7.5"></path>
            <path d="M5 9.5V21h14V9.5"></path>
            break;
        case "link":
            <path d="M9 12a3 3 0 0 1 3-3h3a3 3 0 0 1 0 6h-3"></path>
            <path d="M15 12a3 3 0 0 1-3 3H9a3 3 0 1 1 0-6h3"></path>
            break;
        case "logout":
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <path d="M16 17l5-5-5-5"></path>
            <path d="M21 12H9"></path>
            break;
        case "layers":
            <path d="M12 3l9 5-9 5-9-5 9-5z"></path>
            <path d="M3 13l9 5 9-5"></path>
            <path d="M3 18l9 5 9-5"></path>
            break;
        case "menu":
            <path d="M4 7h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 17h16"></path>
            break;
        case "music":
            <path d="M9 18V7l10-2v11"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
            break;
        case "pause":
            <rect x="6" y="5" width="4" height="14" rx="1"></rect>
            <rect x="14" y="5" width="4" height="14" rx="1"></rect>
            break;
        case "play":
            <path d="M8 6l10 6-10 6z"></path>
            break;
        case "plus":
            <path d="M12 5v14"></path>
            <path d="M5 12h14"></path>
            break;
        case "queue":
            <path d="M4 6h16"></path>
            <path d="M4 12h10"></path>
            <path d="M4 18h10"></path>
            <path d="M18 11l3 2-3 2z"></path>
            break;
        case "radio":
            <rect x="3" y="7" width="18" height="12" rx="3"></rect>
            <path d="M7 7l9-4"></path>
            <circle cx="8.5" cy="13" r="2"></circle>
            <path d="M14 12h4"></path>
            <path d="M14 15h3"></path>
            break;
        case "refresh":
            <path d="M20 11a8 8 0 0 0-14.9-3"></path>
            <path d="M4 4v4h4"></path>
            <path d="M4 13a8 8 0 0 0 14.9 3"></path>
            <path d="M20 20v-4h-4"></path>
            break;
        case "shuffle":
            <path d="M16 3h5v5"></path>
            <path d="M4 20l6-6"></path>
            <path d="M21 3l-7 7"></path>
            <path d="M14 14l7 7"></path>
            <path d="M16 21h5v-5"></path>
            <path d="M4 4l5 5"></path>
            break;
        case "search":
            <circle cx="11" cy="11" r="6"></circle>
            <path d="M20 20l-3.5-3.5"></path>
            break;
        case "signal":
            <path d="M5 18v-2"></path>
            <path d="M10 18v-5"></path>
            <path d="M15 18v-8"></path>
            <path d="M20 18V6"></path>
            break;
        case "skip-next":
            <path d="M5 5l9 7-9 7z"></path>
            <path d="M18 5v14"></path>
            break;
        case "speaker":
            <rect x="7" y="3" width="10" height="18" rx="2"></rect>
            <circle cx="12" cy="17" r="1"></circle>
            <circle cx="12" cy="9" r="3"></circle>
            break;
        case "speakers":
            <rect x="3" y="5" width="7" height="14" rx="2"></rect>
            <rect x="14" y="3" width="7" height="18" rx="2"></rect>
            <circle cx="6.5" cy="15" r="1"></circle>
            <circle cx="6.5" cy="10" r="2"></circle>
            <circle cx="17.5" cy="17" r="1"></circle>
            <circle cx="17.5" cy="9" r="3"></circle>
            break;
        case "spotify":
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M8 10.5c2.8-1 5.8-.8 8 .6"></path>
            <path d="M8.8 13.2c2-.7 4.2-.5 5.8.5"></path>
            <path d="M9.8 15.7c1.4-.4 2.8-.3 4 .4"></path>
            break;
        case "star":
            <path d="M12 3.5l2.8 5.68 6.27.91-4.54 4.42 1.07 6.24L12 17.8l-5.61 2.95 1.07-6.24L2.92 10.1l6.27-.91L12 3.5z"></path>
            break;
        case "status":
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M9.5 12.5l1.8 1.8 3.7-4.1"></path>
            break;
        case "settings":
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9V20a2 2 0 1 1-4 0v-.2a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6H4a2 2 0 1 1 0-4h.2a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1 1 0 0 0 1.1.2 1 1 0 0 0 .6-.9V4a2 2 0 1 1 4 0v.2a1 1 0 0 0 .6.9 1 1 0 0 0 1.1-.2l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1 1 0 0 0-.2 1.1 1 1 0 0 0 .9.6H20a2 2 0 1 1 0 4h-.2a1 1 0 0 0-.9.6z"></path>
            break;
        case "trash":
            <path d="M4 7h16"></path>
            <path d="M10 11v6"></path>
            <path d="M14 11v6"></path>
            <path d="M6 7l1 12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-12"></path>
            <path d="M9 7V4h6v3"></path>
            break;
        case "unlink":
            <path d="M9 9l6 6"></path>
            <path d="M15 9l-6 6"></path>
            <path d="M7.5 14.5l-1.8 1.8a3 3 0 0 1-4.2-4.2L4 9.6"></path>
            <path d="M20 14.4l2.5-2.5a3 3 0 1 0-4.2-4.2L16.5 9.5"></path>
            break;
        case "video":
            <rect x="3" y="6" width="18" height="12" rx="3"></rect>
            <path d="M10 9l5 3-5 3z"></path>
            break;
        case "volume":
            <path d="M5 10v4h4l5 4V6l-5 4z"></path>
            <path d="M18 9a5 5 0 0 1 0 6"></path>
            <path d="M20.5 6.5a8.5 8.5 0 0 1 0 11"></path>
            break;
        case "wave":
            <path d="M3 12c2 0 2-4 4-4s2 8 4 8 2-8 4-8 2 4 4 4 2-2 2-2"></path>
            break;
        case "youtube":
            <path d="M4 9.5c0-2 1.6-3.5 3.6-3.7 2-.2 4-.3 4.4-.3s2.4.1 4.4.3c2 .2 3.6 1.7 3.6 3.7v5c0 2-1.6 3.5-3.6 3.7-2 .2-4 .3-4.4.3s-2.4-.1-4.4-.3c-2-.2-3.6-1.7-3.6-3.7z"></path>
            <path d="M10 9l5 3-5 3z"></path>
            break;
        case "user":
            <path d="M20 21a8 8 0 0 0-16 0"></path>
            <circle cx="12" cy="8" r="4"></circle>
            break;
        case "x":
            <path d="M6 6l12 12"></path>
            <path d="M18 6L6 18"></path>
            break;
        default:
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 8v4"></path>
            <path d="M12 16h.01"></path>
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired]
    public string Name { get; set; } = default!;

    [Parameter]
    public int Size { get; set; } = 20;

    [Parameter]
    public double StrokeWidth { get; set; } = 1.8;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public bool Decorative { get; set; } = true;

    [Parameter]
    public string? Title { get; set; }

    private string SvgClass => string.IsNullOrWhiteSpace(Class) ? "app-icon" : $"app-icon {Class}";

    private string? AriaLabel => Decorative ? null : (string.IsNullOrWhiteSpace(Title) ? Name : Title);
}
