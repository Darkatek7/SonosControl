                        <AppIcon Icon="AppIcon.AppIconType.Home" Width="18" Height="18" />
                        <span>Home</span>
                    </NavLink>
            </div>
            <div class="nav-item">
                    <NavLink class="nav-link" href="lookup">
                        <AppIcon Icon="AppIcon.AppIconType.Search" Width="18" Height="18" />
