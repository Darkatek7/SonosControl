                    </NavLink>
            </div>

            <AuthorizeView Roles="admin,superadmin">
                <Authorized>
                    <div class="nav-divider" aria-hidden="true"></div>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="config">
                            <AppIcon Icon="AppIcon.AppIconType.Settings" Width="18" Height="18" />
