@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-page-shell">
    <section class="auth-brand-panel" aria-label="SonosControl">
        <span class="spotify-eyebrow">Command Center</span>
        <h1>SonosControl</h1>
        <p>Sign in to manage rooms, queues, schedules, recommendations, and system settings from one focused console.</p>
        <div class="auth-brand-panel__meta">
            <span>Playback</span>
            <span>Automation</span>
            <span>Insights</span>
        </div>
    </section>

    <form id="loginForm" method="post" action="/auth/login" class="auth-console-card">
        @Html.AntiForgeryToken()
        <div class="auth-console-card__header">
            <div class="auth-console-card__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
            <div>
                <span class="spotify-eyebrow">Access</span>
                <h2>Welcome back</h2>
                <p>Use your SonosControl account to continue.</p>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center py-2" role="alert">@ViewBag.Error</div>
        }
        @if (ViewBag.Registered == true)
        {
            <div class="alert alert-success text-center py-2" role="status">Account created. You can now sign in.</div>
        }
        @if (Context.Request.Query["error"] == "lockedout")
        {
             <div class="alert alert-warning text-center py-2" role="alert">
                Account locked due to too many failed attempts.<br>Please try again in 5 minutes.
            </div>
        }

        <div class="form-floating-group">
            <div class="form-floating">
                <input id="username" name="username" type="text" class="form-control auth-input" placeholder=" " required autofocus />
                <label for="username" class="form-label-float">Username</label>
            </div>

            <div class="form-floating">
                <input id="password" name="password" type="password" class="form-control auth-input" placeholder=" " required />
                <label for="password" class="form-label-float">Password</label>
            </div>
        </div>

        <div class="form-check auth-console-card__remember">
            <input id="rememberMe" name="rememberMe" type="checkbox" value="true" checked class="form-check-input auth-checkbox" />
            <input type="hidden" name="rememberMe" value="false" />
            <label for="rememberMe" class="form-check-label">Remember Me</label>
        </div>

        <button id="loginBtn" type="submit" class="btn btn-primary w-100 auth-submit">
            <span id="loginBtnText">Sign In</span>
            <span id="loginSpinner" class="d-none">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                Signing in...
            </span>
        </button>

        @if (ViewBag.AllowRegistration == true)
        {
            <div class="auth-console-card__footer">
                <a href="/register" class="auth-link text-decoration-none">Don’t have an account? <span class="auth-link-highlight">Register</span></a>
            </div>
        }
    </form>
</div>

<script>
    document.getElementById('loginForm').addEventListener('submit', function() {
        var btn = document.getElementById('loginBtn');
        var text = document.getElementById('loginBtnText');
        var spinner = document.getElementById('loginSpinner');

        btn.classList.add('disabled');
        btn.style.pointerEvents = 'none';

        text.classList.add('d-none');
        spinner.classList.remove('d-none');
    });
</script>
