@page "/scenes"
@using System.Globalization
@using SonosControl.Web.Services
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISceneOrchestrationService SceneOrchestrationService
@inject IJSRuntime JS
@attribute [Authorize(Roles = "admin,operator,superadmin")]

<PageTitle>Scenes - Sonos Control</PageTitle>

<div class="scenes-console-shell">
    <section class="scenes-hero" aria-labelledby="scenes-heading">
        <div class="scenes-hero__copy">
            <span class="spotify-eyebrow">Presets</span>
            <h1 id="scenes-heading">Scenes</h1>
            <p>Create one-tap room states with source, speaker targets, volume, synced playback, and optional timers.</p>
        </div>
        <div class="scenes-hero__actions">
            <div class="scenes-hero__stat">
                <span><Icon Name="scenes" Size="17" /> Configured</span>
                <strong>@(_settings?.Scenes?.Count ?? 0)</strong>
            </div>
            <div class="scenes-hero__stat">
                <span><Icon Name="check" Size="17" /> Enabled</span>
                <strong>@GetEnabledSceneCount()</strong>
            </div>
            @if (_canManage)
            {
                <button class="btn btn-primary scenes-new-button" @onclick="CreateNewScene"><Icon Name="plus" Size="16" /> New Scene</button>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") scenes-alert" role="status">@_statusMessage</div>
    }

    @if (_settings is null)
    {
        <section class="scenes-panel scenes-empty-state">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <strong>Loading scenes...</strong>
        </section>
    }
    else
    {
        <section class="scenes-workspace">
            <aside class="scenes-panel scenes-list-panel" aria-label="Configured scenes">
                <div class="scenes-panel__header">
                    <div>
                        <span class="spotify-eyebrow">Library</span>
                        <h2><Icon Name="layers" Size="18" /> Scene presets</h2>
                    </div>
                </div>

                @if (_settings.Scenes.Any())
                {
                    <div class="scenes-list">
                        @foreach (var scene in _settings.Scenes.OrderBy(s => s.Name))
                        {
                            <article class="scene-card @GetSceneRowClass(scene)">
                                <button type="button" class="scene-card__main scene-select-link" @onclick="() => EditScene(scene)">
                                    <span class="scene-card__icon"><Icon Name="scenes" Size="18" /></span>
                                    <span class="scene-card__copy">
                                        <span class="scene-card__title">@scene.Name</span>
                                        <span class="scene-card__meta">@GetSourceLabel(scene.SourceType) · @GetSpeakerCount(scene) speakers</span>
                                        @if (!scene.Enabled)
                                        {
                                            <span class="scene-card__status scene-card__status--disabled">Disabled</span>
                                        }
                                    </span>
                                </button>
                                <div class="scene-card__actions">
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => ApplyScene(scene)" disabled="@_isApplying" aria-label="@($"Apply {scene.Name}")" title="@($"Apply {scene.Name}")">
                                        <Icon Name="play" Size="15" />
                                    </button>
                                    @if (_canManage)
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteScene(scene)" disabled="@_isSaving" aria-label="@($"Delete {scene.Name}")" title="@($"Delete {scene.Name}")">
                                            <Icon Name="trash" Size="15" />
                                        </button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="scenes-empty-state">
                        <Icon Name="scenes" Size="24" />
                        <strong>No scenes configured.</strong>
                        <span>Create a scene to save source, speaker, and volume presets.</span>
                    </div>
                }
            </aside>

            <main class="scenes-panel scenes-editor-panel" aria-label="Scene editor">
                <div class="scenes-panel__header">
                    <div>
                        <span class="spotify-eyebrow">Builder</span>
                        <h2><Icon Name="settings" Size="18" /> Scene command center</h2>
                    </div>
                    @if (_editingScene is not null)
                    {
                        <span class="scenes-editor-state">@(_editingScene.Enabled ? "Enabled" : "Disabled")</span>
                    }
                </div>

                @if (_editingScene is null)
                {
                    <div class="scenes-empty-state scene-muted-alert">
                        <Icon Name="edit" Size="24" />
                        <strong>Select a scene or create a new one.</strong>
                        <span>Use the library on the left to edit, apply, or delete a preset.</span>
                    </div>
                }
                else
                {
                    <div class="scenes-editor-grid">
                        <section class="scenes-editor-card scenes-editor-card--identity">
                            <div class="scenes-editor-card__header">
                                <h3><Icon Name="edit" Size="16" /> Identity</h3>
                            </div>
                            <div class="scenes-form-grid">
                                <div class="scenes-field scenes-field--wide">
                                    <label class="form-label">Name</label>
                                    <input class="form-control" @bind="_editingScene.Name" disabled="@(!_canManage)" />
                                </div>
                                <div class="scenes-field">
                                    <label class="form-label">Enabled</label>
                                    <div class="form-check form-switch scenes-switch">
                                        <input class="form-check-input" type="checkbox" @bind="_editingScene.Enabled" disabled="@(!_canManage)" />
                                    </div>
                                </div>
                                <div class="scenes-field scenes-field--full">
                                    <label class="form-label">Description</label>
                                    <input class="form-control" @bind="_editingScene.Description" disabled="@(!_canManage)" />
                                </div>
                            </div>
                        </section>

                        <section class="scenes-editor-card">
                            <div class="scenes-editor-card__header">
                                <h3><Icon Name="music" Size="16" /> Source</h3>
                            </div>
                            <div class="scenes-form-grid">
                                <div class="scenes-field">
                                    <label class="form-label">Source Type</label>
                                    <select class="form-select" @bind="SceneSourceTypeValue" disabled="@(!_canManage)">
                                        <option value="@SceneSourceType.None">None</option>
                                        <option value="@SceneSourceType.Station">Station</option>
                                        <option value="@SceneSourceType.Spotify">Spotify</option>
                                        <option value="@SceneSourceType.YouTubeMusic">YouTube Music</option>
                                    </select>
                                </div>
                                <div class="scenes-field">
                                    <label class="form-label">Source Item</label>
                                    <select class="form-select" @bind="SelectedSourceItemValue" disabled="@(!_canManage || _editingScene.SourceType == SceneSourceType.None)">
                                        <option value="@CustomSourceItemValue">Custom URL</option>
                                        @foreach (var option in GetSourceCatalogOptions())
                                        {
                                            <option value="@option.Url">@option.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="scenes-field scenes-field--full">
                                    <label class="form-label">Source URL</label>
                                    <input class="form-control"
                                           @bind="_editingScene.SourceUrl"
                                           @bind:after="HandleSourceUrlChanged"
                                           disabled="@(!_canManage || _editingScene.SourceType == SceneSourceType.None)" />
                                </div>
                            </div>
                        </section>

                        <section class="scenes-editor-card">
                            <div class="scenes-editor-card__header">
                                <h3><Icon Name="timer" Size="16" /> Playback</h3>
                            </div>
                            <div class="scenes-form-grid">
                                <div class="scenes-field">
                                    <label class="form-label">Timer (minutes)</label>
                                    <input class="form-control" type="number" min="0" @bind="TimerMinutesValue" disabled="@(!_canManage)" />
                                </div>
                                <div class="scenes-field">
                                    <label class="form-label">Synced playback</label>
                                    <div class="form-check form-switch scenes-switch">
                                        <input class="form-check-input" type="checkbox" @bind="_editingScene.IsSyncedPlayback" disabled="@(!_canManage)" />
                                    </div>
                                </div>
                                <div class="scenes-field scenes-field--full">
                                    <label class="form-label">Master Speaker</label>
                                    <select class="form-select" @bind="_editingScene.MasterSpeakerIp" disabled="@(!_canManage || !_editingScene.IsSyncedPlayback)">
                                        <option value="">Auto</option>
                                        @foreach (var speaker in _settings.Speakers.OrderBy(s => s.Name))
                                        {
                                            <option value="@speaker.IpAddress">@speaker.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </section>

                        <section class="scenes-editor-card scenes-editor-card--speakers">
                            <div class="scenes-editor-card__header">
                                <h3><Icon Name="speaker" Size="16" /> Speaker mixer</h3>
                                <span>@GetSpeakerTargetSummary()</span>
                            </div>
                            <div class="scenes-speaker-list">
                                @foreach (var speaker in _settings.Speakers.OrderBy(s => s.Name))
                                {
                                    var action = GetOrCreateAction(speaker.IpAddress);
                                    <article class="scenes-speaker-row">
                                        <div class="scenes-speaker-row__use">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   checked="@action.IncludeInPlayback"
                                                   @onchange="e => SetSpeakerIncluded(speaker.IpAddress, e.Value)"
                                                   disabled="@(!_canManage)" />
                                        </div>
                                        <div class="scenes-speaker-row__name">
                                            <strong>@speaker.Name</strong>
                                            <small>@speaker.IpAddress</small>
                                        </div>
                                        <label class="scenes-speaker-row__volume">
                                            <span>Volume</span>
                                            <input class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   max="100"
                                                   value="@FormatVolume(action.Volume)"
                                                   @onchange="e => SetSpeakerVolume(speaker.IpAddress, e.Value)"
                                                   disabled="@(!_canManage || !action.IncludeInPlayback)" />
                                        </label>
                                        <label class="scenes-speaker-row__master">
                                            <input class="form-check-input"
                                                   type="radio"
                                                   name="sceneMasterSpeaker"
                                                   checked="@IsMasterSpeaker(speaker.IpAddress)"
                                                   @onchange="@(() => SetMasterSpeaker(speaker.IpAddress))"
                                                   disabled="@(!_canManage || !_editingScene.IsSyncedPlayback || !action.IncludeInPlayback)" />
                                            <span>Master</span>
                                        </label>
                                    </article>
                                }
                            </div>
                        </section>

                        <div class="scenes-editor-actions">
                            @if (_canManage)
                            {
                                <button class="btn btn-primary" @onclick="SaveScene" disabled="@_isSaving">
                                    @if (_isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    }
                                    else
                                    {
                                        <Icon Name="check" Size="16" />
                                    }
                                    Save Scene
                                </button>
                            }
                            <button class="btn btn-outline-success" @onclick="() => ApplyScene(_editingScene)" disabled="@_isApplying">
                                @if (_isApplying)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                }
                                else
                                {
                                    <Icon Name="play" Size="16" />
                                }
                                Apply Now
                            </button>
                        </div>
                    </div>
                }
            </main>
        </section>
    }
</div>

@code {
    private SonosSettings? _settings;
    private Scene? _editingScene;
    private string? _selectedSceneId;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isSaving;
    private bool _isApplying;
    private bool _canManage;
    private const string CustomSourceItemValue = "__custom__";
    private string _selectedSourceItemValue = CustomSourceItemValue;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _canManage = authState.User.IsInRole("admin") || authState.User.IsInRole("superadmin");
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _settings = await _uow.ISettingsRepo.GetSettings() ?? new SonosSettings();
        _settings.Scenes ??= new();
        _settings.Speakers ??= new();
        _settings.Stations ??= new();
        _settings.SpotifyTracks ??= new();
        _settings.YouTubeMusicCollections ??= new();
    }

    private int GetEnabledSceneCount() => _settings?.Scenes?.Count(scene => scene.Enabled) ?? 0;

    private string GetSpeakerTargetSummary()
    {
        if (_editingScene is null)
        {
            return "No scene selected";
        }

        var count = GetSpeakerCount(_editingScene);
        return count switch
        {
            0 => "No speakers selected",
            1 => "1 speaker selected",
            _ => $"{count} speakers selected"
        };
    }

    private static string GetSourceLabel(SceneSourceType sourceType) => sourceType switch
    {
        SceneSourceType.Station => "Station",
        SceneSourceType.Spotify => "Spotify",
        SceneSourceType.YouTubeMusic => "YouTube",
        _ => "None"
    };

    private int GetSpeakerCount(Scene scene)
    {
        if (scene.Actions?.Any() == true)
        {
            return scene.Actions.Count(a => a.IncludeInPlayback);
        }

        return scene.SpeakerIps?.Count ?? 0;
    }

    private string GetSceneRowClass(Scene scene)
    {
        return string.Equals(scene.Id, _selectedSceneId, StringComparison.OrdinalIgnoreCase)
            ? "scene-selected-row"
            : string.Empty;
    }

    private void CreateNewScene()
    {
        if (_settings is null)
        {
            return;
        }

        _editingScene = new Scene
        {
            Name = $"Scene {_settings.Scenes.Count + 1}",
            Enabled = true,
            IsSyncedPlayback = true,
            SourceType = SceneSourceType.None,
            TimerMinutes = null,
            Actions = _settings.Speakers
                .Select(s => new SceneAction
                {
                    SpeakerIp = s.IpAddress,
                    IncludeInPlayback = true,
                    Volume = s.StartupVolume
                })
                .ToList()
        };

        _selectedSceneId = null;
        _selectedSourceItemValue = CustomSourceItemValue;
        EnsureMasterSpeaker();
    }

    private void EditScene(Scene scene)
    {
        _editingScene = CloneScene(scene);
        _selectedSceneId = scene.Id;
        EnsureActionCoverage();
        EnsureMasterSpeaker();
        SyncSourceSelectionWithScene();
    }

    private async Task SaveScene()
    {
        if (!_canManage || _settings is null || _editingScene is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editingScene.Name))
        {
            ShowStatus("Scene name is required.", true);
            return;
        }

        if (_editingScene.SourceType != SceneSourceType.None && string.IsNullOrWhiteSpace(_editingScene.SourceUrl))
        {
            ShowStatus("Source URL is required for non-empty source type.", true);
            return;
        }

        _isSaving = true;
        try
        {
            _editingScene.Actions = _editingScene.Actions
                .Where(a => !string.IsNullOrWhiteSpace(a.SpeakerIp))
                .GroupBy(a => a.SpeakerIp, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.First())
                .ToList();
            _editingScene.SpeakerIps = _editingScene.Actions
                .Where(a => a.IncludeInPlayback)
                .Select(a => a.SpeakerIp)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
            _editingScene.LastModifiedUtc = DateTime.UtcNow;

            var existing = _settings.Scenes.FirstOrDefault(s => string.Equals(s.Id, _editingScene.Id, StringComparison.OrdinalIgnoreCase));
            if (existing is null)
            {
                _editingScene.Id = string.IsNullOrWhiteSpace(_editingScene.Id) ? Guid.NewGuid().ToString("N") : _editingScene.Id;
                _settings.Scenes.Add(CloneScene(_editingScene));
                _selectedSceneId = _editingScene.Id;
            }
            else
            {
                var index = _settings.Scenes.IndexOf(existing);
                _settings.Scenes[index] = CloneScene(_editingScene);
                _selectedSceneId = _editingScene.Id;
            }

            await _uow.ISettingsRepo.WriteSettings(_settings);
            ShowStatus("Scene saved.");
            await LoadSettingsAsync();

            if (!string.IsNullOrWhiteSpace(_selectedSceneId))
            {
                var refreshed = _settings.Scenes.FirstOrDefault(s => s.Id == _selectedSceneId);
                if (refreshed is not null)
                {
                    _editingScene = CloneScene(refreshed);
                    SyncSourceSelectionWithScene();
                }
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to save scene: {ex.Message}", true);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteScene(Scene scene)
    {
        if (!_canManage || _settings is null)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete scene '{scene.Name}'?");
        if (!confirmed)
        {
            return;
        }

        _settings.Scenes.RemoveAll(s => string.Equals(s.Id, scene.Id, StringComparison.OrdinalIgnoreCase));
        await _uow.ISettingsRepo.WriteSettings(_settings);
        ShowStatus("Scene deleted.");

        if (string.Equals(_selectedSceneId, scene.Id, StringComparison.OrdinalIgnoreCase))
        {
            _selectedSceneId = null;
            _editingScene = null;
        }
    }

    private async Task ApplyScene(Scene scene)
    {
        _isApplying = true;
        try
        {
            var result = await SceneOrchestrationService.ApplySceneByIdAsync(scene.Id, await GetUserNameOrUnknownAsync());
            ShowStatus(result.Success ? result.Message : $"Scene apply failed: {result.Message}", !result.Success);
        }
        finally
        {
            _isApplying = false;
        }
    }

    private SceneSourceType SceneSourceTypeValue
    {
        get => _editingScene?.SourceType ?? SceneSourceType.None;
        set
        {
            if (_editingScene is null)
            {
                return;
            }

            _editingScene.SourceType = value;
            if (value == SceneSourceType.None)
            {
                _editingScene.SourceUrl = null;
            }

            SyncSourceSelectionWithScene();
        }
    }

    private string SelectedSourceItemValue
    {
        get => _selectedSourceItemValue;
        set
        {
            _selectedSourceItemValue = string.IsNullOrWhiteSpace(value) ? CustomSourceItemValue : value;
            if (_editingScene is null || _editingScene.SourceType == SceneSourceType.None)
            {
                return;
            }

            if (string.Equals(_selectedSourceItemValue, CustomSourceItemValue, StringComparison.Ordinal))
            {
                return;
            }

            _editingScene.SourceUrl = _selectedSourceItemValue;
        }
    }

    private int TimerMinutesValue
    {
        get => _editingScene?.TimerMinutes ?? 0;
        set
        {
            if (_editingScene is null)
            {
                return;
            }

            _editingScene.TimerMinutes = value <= 0 ? null : value;
        }
    }

    private IReadOnlyList<(string Url, string Name)> GetSourceCatalogOptions()
    {
        if (_settings is null || _editingScene is null)
        {
            return Array.Empty<(string Url, string Name)>();
        }

        return _editingScene.SourceType switch
        {
            SceneSourceType.Station => _settings.Stations
                .Where(s => !string.IsNullOrWhiteSpace(s.Url))
                .Select(s => (s.Url.Trim(), string.IsNullOrWhiteSpace(s.Name) ? s.Url.Trim() : s.Name.Trim()))
                .DistinctBy(s => s.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s.Item2)
                .ToList(),
            SceneSourceType.Spotify => _settings.SpotifyTracks
                .Where(s => !string.IsNullOrWhiteSpace(s.Url))
                .Select(s => (s.Url.Trim(), string.IsNullOrWhiteSpace(s.Name) ? s.Url.Trim() : s.Name.Trim()))
                .DistinctBy(s => s.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s.Item2)
                .ToList(),
            SceneSourceType.YouTubeMusic => _settings.YouTubeMusicCollections
                .Where(s => !string.IsNullOrWhiteSpace(s.Url))
                .Select(s => (s.Url.Trim(), string.IsNullOrWhiteSpace(s.Name) ? s.Url.Trim() : s.Name.Trim()))
                .DistinctBy(s => s.Item1, StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s.Item2)
                .ToList(),
            _ => Array.Empty<(string Url, string Name)>()
        };
    }

    private void HandleSourceUrlChanged()
    {
        SyncSourceSelectionWithScene();
    }

    private void SyncSourceSelectionWithScene()
    {
        if (_editingScene is null || _editingScene.SourceType == SceneSourceType.None)
        {
            _selectedSourceItemValue = CustomSourceItemValue;
            return;
        }

        if (string.IsNullOrWhiteSpace(_editingScene.SourceUrl))
        {
            _selectedSourceItemValue = CustomSourceItemValue;
            return;
        }

        var matched = FindMatchingCatalogUrl(_editingScene.SourceType, _editingScene.SourceUrl);
        _selectedSourceItemValue = matched ?? CustomSourceItemValue;
    }

    private string? FindMatchingCatalogUrl(SceneSourceType sourceType, string? sourceUrl)
    {
        if (string.IsNullOrWhiteSpace(sourceUrl))
        {
            return null;
        }

        var normalized = sourceUrl.Trim();
        var options = sourceType switch
        {
            SceneSourceType.Station => _settings?.Stations?.Select(s => s.Url),
            SceneSourceType.Spotify => _settings?.SpotifyTracks?.Select(s => s.Url),
            SceneSourceType.YouTubeMusic => _settings?.YouTubeMusicCollections?.Select(s => s.Url),
            _ => null
        };

        if (options is null)
        {
            return null;
        }

        return options
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Select(url => url!.Trim())
            .FirstOrDefault(url => string.Equals(url, normalized, StringComparison.OrdinalIgnoreCase));
    }

    private SceneAction GetOrCreateAction(string speakerIp)
    {
        if (_editingScene is null)
        {
            return new SceneAction { SpeakerIp = speakerIp };
        }

        var existing = _editingScene.Actions.FirstOrDefault(a => string.Equals(a.SpeakerIp, speakerIp, StringComparison.OrdinalIgnoreCase));
        if (existing is not null)
        {
            return existing;
        }

        var action = new SceneAction
        {
            SpeakerIp = speakerIp,
            IncludeInPlayback = false
        };
        _editingScene.Actions.Add(action);
        return action;
    }

    private void SetSpeakerIncluded(string speakerIp, object? value)
    {
        if (_editingScene is null)
        {
            return;
        }

        var action = GetOrCreateAction(speakerIp);
        action.IncludeInPlayback = value is bool b && b;
        if (!action.IncludeInPlayback && string.Equals(_editingScene.MasterSpeakerIp, speakerIp, StringComparison.OrdinalIgnoreCase))
        {
            _editingScene.MasterSpeakerIp = null;
            EnsureMasterSpeaker();
        }
    }

    private void SetSpeakerVolume(string speakerIp, object? value)
    {
        if (_editingScene is null)
        {
            return;
        }

        var action = GetOrCreateAction(speakerIp);
        if (int.TryParse(value?.ToString(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
        {
            action.Volume = Math.Clamp(parsed, 0, 100);
        }
        else
        {
            action.Volume = null;
        }
    }

    private static string FormatVolume(int? volume) => volume?.ToString(CultureInfo.InvariantCulture) ?? string.Empty;

    private bool IsMasterSpeaker(string speakerIp)
    {
        return _editingScene is not null && string.Equals(_editingScene.MasterSpeakerIp, speakerIp, StringComparison.OrdinalIgnoreCase);
    }

    private void SetMasterSpeaker(string speakerIp)
    {
        if (_editingScene is null)
        {
            return;
        }

        var action = GetOrCreateAction(speakerIp);
        if (!action.IncludeInPlayback)
        {
            return;
        }

        _editingScene.MasterSpeakerIp = speakerIp;
    }

    private void EnsureActionCoverage()
    {
        if (_editingScene is null || _settings is null)
        {
            return;
        }

        foreach (var speaker in _settings.Speakers)
        {
            GetOrCreateAction(speaker.IpAddress);
        }
    }

    private void EnsureMasterSpeaker()
    {
        if (_editingScene is null)
        {
            return;
        }

        if (!_editingScene.IsSyncedPlayback)
        {
            _editingScene.MasterSpeakerIp = null;
            return;
        }

        var included = _editingScene.Actions.Where(a => a.IncludeInPlayback).Select(a => a.SpeakerIp).ToList();
        if (!included.Any())
        {
            _editingScene.MasterSpeakerIp = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(_editingScene.MasterSpeakerIp)
            || !included.Contains(_editingScene.MasterSpeakerIp, StringComparer.OrdinalIgnoreCase))
        {
            _editingScene.MasterSpeakerIp = included[0];
        }
    }

    private static Scene CloneScene(Scene source)
    {
        return new Scene
        {
            Id = source.Id,
            Name = source.Name,
            Description = source.Description,
            Enabled = source.Enabled,
            SourceType = source.SourceType,
            SourceUrl = source.SourceUrl,
            IsSyncedPlayback = source.IsSyncedPlayback,
            MasterSpeakerIp = source.MasterSpeakerIp,
            TimerMinutes = source.TimerMinutes,
            SpeakerIps = source.SpeakerIps?.ToList() ?? new(),
            Actions = source.Actions?.Select(a => new SceneAction
            {
                SpeakerIp = a.SpeakerIp,
                Volume = a.Volume,
                IncludeInPlayback = a.IncludeInPlayback,
                IsMaster = a.IsMaster
            }).ToList() ?? new(),
            LastModifiedUtc = source.LastModifiedUtc
        };
    }

    private async Task<string> GetUserNameOrUnknownAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.Name ?? "Unknown";
    }

    private void ShowStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }
}
