@* Routed through AdministrationPage. *@
@implements IDisposable
@using SonosControl.DAL.Models
@using SonosControl.Web.Services
@inject IServiceProvider Services
@attribute [Authorize(Roles = "admin,superadmin")]

@if (_settings is null)
{
    <div class="workspace-loading" role="status">
        <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
        Loading settings…
    </div>
}
else
{
    <div class="config-console-shell">
        <header class="config-console-hero">
            <div class="config-console-hero__copy">
                <span class="workspace-eyebrow">SonosControl</span>
                <h1>System settings</h1>
                <p>Configure playback defaults, notifications, and account access.</p>
            </div>
            <div class="config-console-hero__status"
                 aria-label="Configuration save status"
                 aria-live="polite"
                 role="status">
                <Icon Name="@SaveStateIcon" Size="18" />
                <span>@SaveStateLabel</span>
                @if (_autosave?.State == SettingsSaveState.Error)
                {
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            @onclick="RetrySaveAsync">
                        Retry
                    </button>
                }
            </div>
        </header>

        <main class="config-workspace config-workspace--focused">
            <section class="config-panel" aria-labelledby="config-notifications-heading">
                <div class="config-panel__header">
                    <div>
                        <span class="workspace-eyebrow">Notifications</span>
                        <h2 id="config-notifications-heading">Webhook destinations</h2>
                    </div>
                    <span class="config-panel__meta">Changes save automatically</span>
                </div>

                <div class="config-field-stack">
                    <div class="config-field">
                        <label class="form-label config-label" for="discordWebhook">
                            <Icon Name="link" Size="16" /> Discord webhook
                        </label>
                        @if (_editingDiscordWebhook)
                        {
                            <div class="input-group">
                                <input id="discordWebhook"
                                       type="url"
                                       class="form-control"
                                       @bind-value="_settings.DiscordWebhookUrl"
                                       @bind-value:event="oninput"
                                       @bind-value:after="SaveSettings"
                                       placeholder="https://discord.com/api/webhooks/…"
                                       aria-label="Discord Webhook URL"
                                       autofocus />
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        @onclick="() => _editingDiscordWebhook = false"
                                        aria-label="Save Discord Webhook">
                                    <Icon Name="check" Size="15" /> Done
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <div class="form-control text-muted text-truncate surface-2">
                                    @GetTruncatedUrl(_settings.DiscordWebhookUrl)
                                </div>
                                <button type="button"
                                        class="btn btn-outline-primary config-icon-button"
                                        @onclick="() => _editingDiscordWebhook = true"
                                        aria-label="Edit Discord Webhook">
                                    <Icon Name="edit" Size="15" />
                                </button>
                            </div>
                        }
                        <div class="form-text">Playback and error notifications are sent to this endpoint.</div>
                    </div>

                    <div class="config-field">
                        <label class="form-label config-label" for="teamsWebhook">
                            <Icon Name="link" Size="16" /> Teams webhook
                        </label>
                        @if (_editingTeamsWebhook)
                        {
                            <div class="input-group">
                                <input id="teamsWebhook"
                                       type="url"
                                       class="form-control"
                                       @bind-value="_settings.TeamsWebhookUrl"
                                       @bind-value:event="oninput"
                                       @bind-value:after="SaveSettings"
                                       placeholder="https://…"
                                       aria-label="Teams Webhook URL"
                                       autofocus />
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        @onclick="() => _editingTeamsWebhook = false"
                                        aria-label="Save Teams Webhook">
                                    <Icon Name="check" Size="15" /> Done
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <div class="form-control text-muted text-truncate surface-2">
                                    @GetTruncatedUrl(_settings.TeamsWebhookUrl)
                                </div>
                                <button type="button"
                                        class="btn btn-outline-primary config-icon-button"
                                        @onclick="() => _editingTeamsWebhook = true"
                                        aria-label="Edit Teams Webhook">
                                    <Icon Name="edit" Size="15" />
                                </button>
                            </div>
                        }
                        <div class="form-text">Teams notifications are sent to this endpoint.</div>
                    </div>
                </div>
            </section>

            <section class="config-panel" aria-labelledby="config-playback-heading">
                <div class="config-panel__header">
                    <div>
                        <span class="workspace-eyebrow">Playback</span>
                        <h2 id="config-playback-heading">Application defaults</h2>
                    </div>
                </div>

                <div class="config-field-stack">
                    <div class="config-field">
                        <label class="form-label config-label" for="autoPlay">
                            <Icon Name="music" Size="16" /> Auto play
                        </label>
                        <select id="autoPlay"
                                class="form-select"
                                @bind="AutoPlaySelection"
                                @bind:event="onchange"
                                @bind:after="SaveSettings">
                            <option value="">None</option>
                            <option value="randomStation">Random station</option>
                            <option value="randomSpotify">Random Spotify item</option>
                            <option value="randomYouTube">Random YouTube item</option>
                            <option value="randomYouTubeMusic">Random YouTube Music item</option>
                            <optgroup label="Stations">
                                @foreach (var station in _settings.Stations)
                                {
                                    <option value="station:@station.Url">@station.Name</option>
                                }
                            </optgroup>
                            <optgroup label="Spotify">
                                @foreach (var track in _settings.SpotifyTracks)
                                {
                                    <option value="spotify:@track.Url">@track.Name</option>
                                }
                            </optgroup>
                            <optgroup label="YouTube">
                                @foreach (var video in _settings.YouTubeCollections)
                                {
                                    <option value="youtubevideo:@video.Url">@video.Name</option>
                                }
                            </optgroup>
                            <optgroup label="YouTube Music">
                                @foreach (var item in _settings.YouTubeMusicCollections)
                                {
                                    <option value="youtubemusic:@item.Url">@item.Name</option>
                                }
                            </optgroup>
                        </select>
                    </div>

                    <div class="config-field">
                        <label class="form-label config-label" for="maxVolume">
                            <Icon Name="volume" Size="16" /> Maximum volume
                        </label>
                        <input id="maxVolume"
                               type="number"
                               class="form-control"
                               min="0"
                               max="100"
                               @bind-value="MaxVolume"
                               @bind-value:event="oninput"
                               @bind-value:after="SaveSettings" />
                        <div class="form-text">Limits volume changes throughout the application.</div>
                    </div>

                    @if (_settings.YouTubeCollections.Any())
                    {
                        <div class="config-field config-field--wide">
                            <span class="form-label config-label">
                                <Icon Name="play" Size="16" /> YouTube playback modes
                            </span>
                            <div class="d-grid gap-2">
                                @foreach (var video in _settings.YouTubeCollections.OrderBy(video => video.Name))
                                {
                                    <div class="row g-2 align-items-center">
                                        <div class="col-12 col-md-6"><strong>@video.Name</strong></div>
                                        <div class="col-12 col-md-6">
                                            <select class="form-select"
                                                    value="@GetYouTubePlaybackModeValue(video)"
                                                    aria-label="@($"Playback mode for {video.Name}")"
                                                    @onchange="eventArgs => SetYouTubePlaybackModeAsync(video, eventArgs.Value?.ToString())">
                                                <option value="@YouTubePlaybackMode.AutoQueueRelated">Auto queue related</option>
                                                <option value="@YouTubePlaybackMode.Single">Single item</option>
                                                @if (YouTubePlaybackModeResolver.IsPlaylistLikeUrl(video.Url))
                                                {
                                                    <option value="@YouTubePlaybackMode.PlaylistOrdered">Playlist ordered</option>
                                                    <option value="@YouTubePlaybackMode.PlaylistShuffle">Playlist shuffle</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section class="config-panel" aria-labelledby="config-access-heading">
                <div class="config-panel__header">
                    <div>
                        <span class="workspace-eyebrow">Access</span>
                        <h2 id="config-access-heading">Registration</h2>
                    </div>
                </div>
                <div class="config-field">
                    <div class="form-check form-switch">
                        <InputCheckbox id="allowRegistration"
                                       class="form-check-input"
                                       @bind-Value="_settings.AllowUserRegistration"
                                       @bind-Value:after="SaveSettings" />
                        <label class="form-check-label" for="allowRegistration">
                            Allow new users to register
                        </label>
                    </div>
                    <div class="form-text">Disable this after the intended accounts have been created.</div>
                </div>
            </section>
        </main>
    </div>
}

@code {
    private SettingsAutosaveCoordinator? _autosave;
    private SonosSettings? _settings;
    private bool _editingDiscordWebhook;
    private bool _editingTeamsWebhook;

    protected override async Task OnInitializedAsync()
    {
        _autosave = Services.GetService(typeof(SettingsAutosaveCoordinator)) as SettingsAutosaveCoordinator;
        if (_autosave is not null)
        {
            _autosave.StateChanged += OnAutosaveStateChanged;
        }

        _settings = await _uow.ISettingsRepo.GetSettings() ?? new SonosSettings();
        NormalizeCollections(_settings);
    }

    private string AutoPlaySelection
    {
        get
        {
            if (_settings is null)
            {
                return string.Empty;
            }

            if (_settings.AutoPlayRandomStation) return "randomStation";
            if (_settings.AutoPlayRandomSpotify) return "randomSpotify";
            if (_settings.AutoPlayRandomYouTube) return "randomYouTube";
            if (_settings.AutoPlayRandomYouTubeMusic) return "randomYouTubeMusic";
            if (!string.IsNullOrEmpty(_settings.AutoPlayStationUrl)) return $"station:{_settings.AutoPlayStationUrl}";
            if (!string.IsNullOrEmpty(_settings.AutoPlaySpotifyUrl)) return $"spotify:{_settings.AutoPlaySpotifyUrl}";
            if (!string.IsNullOrEmpty(_settings.AutoPlayYouTubeUrl)) return $"youtubevideo:{_settings.AutoPlayYouTubeUrl}";
            if (!string.IsNullOrEmpty(_settings.AutoPlayYouTubeMusicUrl)) return $"youtubemusic:{_settings.AutoPlayYouTubeMusicUrl}";
            return string.Empty;
        }
        set
        {
            if (_settings is null)
            {
                return;
            }

            _settings.AutoPlayRandomStation = value == "randomStation";
            _settings.AutoPlayRandomSpotify = value == "randomSpotify";
            _settings.AutoPlayRandomYouTube = value == "randomYouTube";
            _settings.AutoPlayRandomYouTubeMusic = value == "randomYouTubeMusic";
            _settings.AutoPlayStationUrl = ReadSelection(value, "station");
            _settings.AutoPlaySpotifyUrl = ReadSelection(value, "spotify");
            _settings.AutoPlayYouTubeUrl = ReadSelection(value, "youtubevideo");
            _settings.AutoPlayYouTubeMusicUrl = ReadSelection(value, "youtubemusic");
        }
    }

    private int MaxVolume
    {
        get => Math.Clamp(_settings?.MaxVolume ?? 100, 0, 100);
        set
        {
            if (_settings is null)
            {
                return;
            }

            _settings.MaxVolume = Math.Clamp(value, 0, 100);
            _settings.Volume = Math.Min(_settings.Volume, _settings.MaxVolume);
        }
    }

    private async Task SaveSettings()
    {
        if (_settings is null)
        {
            return;
        }

        NormalizeCollections(_settings);
        _settings.MaxVolume = Math.Clamp(_settings.MaxVolume, 0, 100);
        _settings.Volume = Math.Clamp(_settings.Volume, 0, _settings.MaxVolume);

        if (_autosave is not null)
        {
            await _autosave.QueueSaveAsync(_settings);
        }
        else
        {
            await _uow.ISettingsRepo.WriteSettings(_settings);
        }
    }

    private static void NormalizeCollections(SonosSettings settings)
    {
        settings.Speakers ??= [];
        settings.Stations ??= [];
        settings.SpotifyTracks ??= [];
        settings.YouTubeCollections ??= [];
        settings.YouTubeMusicCollections ??= [];
    }

    private static string? ReadSelection(string value, string prefix)
    {
        var expected = $"{prefix}:";
        return value.StartsWith(expected, StringComparison.Ordinal)
            ? value[expected.Length..]
            : null;
    }

    private static string GetYouTubePlaybackModeValue(YouTubeObject video)
        => YouTubePlaybackModeResolver.GetEffectiveMode(video.Url, video.PlaybackMode).ToString();

    private async Task SetYouTubePlaybackModeAsync(YouTubeObject video, string? value)
    {
        if (!Enum.TryParse<YouTubePlaybackMode>(value, true, out var mode))
        {
            return;
        }

        video.PlaybackMode = mode;
        video.PreferredQueueLength ??= YouTubePlaybackModeResolver.DefaultRelatedQueueLength;
        await SaveSettings();
    }

    private static string GetTruncatedUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return "Not configured";
        }

        return url.Length <= 42 ? url : $"{url[..42]}…";
    }

    private string SaveStateLabel => _autosave?.State switch
    {
        SettingsSaveState.Saving => "Saving…",
        SettingsSaveState.Error => $"Save failed: {_autosave.ErrorMessage}",
        _ => "Saved"
    };

    private string SaveStateIcon => _autosave?.State switch
    {
        SettingsSaveState.Error => "alert",
        SettingsSaveState.Saving => "refresh",
        _ => "check"
    };

    private Task RetrySaveAsync() => _autosave?.RetryAsync() ?? Task.CompletedTask;
    private void OnAutosaveStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (_autosave is not null)
        {
            _autosave.StateChanged -= OnAutosaveStateChanged;
        }
    }
}
