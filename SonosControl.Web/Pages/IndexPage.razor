@page "/"
@using System.Text.RegularExpressions
@using System.Linq
@using Radzen.Blazor.Rendering
@using SonosControl.DAL.Interfaces
@using SonosControl.DAL.Models
@using SonosControl.Web.Data
@using SonosControl.Web.Models
@using SonosControl.Web.Pages.Index.Components
@using SonosControl.Web.Services
@using SonosControl.Web.Shared
@implements IAsyncDisposable
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject INotificationService NotificationService
@inject IConfiguration Configuration
@inject ILogger<IndexPage> Logger
@inject IMetricsCollector MetricsCollector
@inject PlaybackUiStateService PlaybackState
@inject IDeviceHealthSnapshotStore DeviceHealthSnapshotStore
@inject ConfiguredTimeZoneService AppTimeZone
@inject HomeLibraryService HomeLibrary
@attribute [Authorize(Roles = "admin,operator,superadmin")]

<PageTitle>Home - SonosControl</PageTitle>

@if (_settings is not null)
{
    <div class="home-shell" data-qa="home-dashboard">
        @{
            var nowLocal = AppTimeZone.Now;
            var activeWindow = ScheduleWindowEvaluator.SelectActiveWindow(_settings.ScheduleWindows, nowLocal);
            var activeScene = GetScene(activeWindow?.SceneId);
            var nextWindow = GetNextScheduleWindow(nowLocal, activeWindow);
            var healthSummary = GetDeviceHealthSummary();
            var libraryItems = _homeLibraryItems;
        }

        @if (!string.IsNullOrWhiteSpace(_commandStatusMessage))
        {
            <div class="alert @(_commandStatusIsError ? "alert-danger" : "alert-success") py-2 home-command-status" role="status" aria-live="polite">
                @_commandStatusMessage
            </div>
        }

        <header class="home-intro">
            <div>
                <span class="home-eyebrow">Today</span>
                <h1>@Greeting</h1>
                <p class="home-intro__sub">Your rooms, favourite sources, and next automation at a glance.</p>
            </div>
            <div class="home-intro__status">
                <span class="home-status-pill @(activeWindow is null ? "is-idle" : "is-active")">
                    @(activeWindow is null ? "Manual control" : "Automation running")
                </span>
                <small>@RefreshTelemetryLabel</small>
            </div>
        </header>

        @if (_settings.Speakers.Any())
        {
            <section class="rooms-section" aria-label="Rooms and device health">
                <header class="rooms-section__head">
                    <div>
                        <span class="home-eyebrow">Rooms</span>
                        <h2>Speakers</h2>
                    </div>
                    <div class="rooms-section__health">
                        <span class="rooms-stat is-online"><strong>@healthSummary.Online</strong> Online</span>
                        <span class="rooms-stat is-offline"><strong>@healthSummary.Offline</strong> Offline</span>
                        <span class="rooms-stat is-unknown"><strong>@healthSummary.Unknown</strong> Unknown</span>
                        <AuthorizeView Roles="admin,superadmin">
                            <Authorized><a class="rooms-section__link" href="/administration/devices">@_settings.Speakers.Count configured</a></Authorized>
                        </AuthorizeView>
                    </div>
                </header>
                <div class="room-grid">
                    @foreach (var speaker in _settings.Speakers.OrderBy(s => s.Name))
                    {
                        var status = healthSummary.ByIp.TryGetValue(speaker.IpAddress, out var value) ? value : null;
                        var isActive = string.Equals(speaker.IpAddress, PlaybackState.ActiveSpeakerIp, StringComparison.OrdinalIgnoreCase);
                        <RoomCard Speaker="speaker"
                                  Health="status"
                                  IsActive="isActive"
                                  ActiveVolume="@PlaybackState.Volume"
                                  MaxVolume="@PlaybackState.MaxVolume"
                                  IsPlaybackLoading="PlaybackState.IsLoading"
                                  OnSetActive="@(() => SetActiveSpeaker(speaker.IpAddress))"
                                  OnVolumeChanged="SetActiveVolume"
                                  OnTogglePlayback="TogglePlayback" />
                    }
                </div>
                @if (_speakerStatuses.Any(s => s.GroupMembers.Any()))
                {
                    <div class="room-groups" aria-label="Grouped speakers">
                        <span class="room-groups__label"><Icon Name="link" Size="14" /> Groups</span>
                        @foreach (var root in _speakerStatuses.Where(s => s.GroupMembers.Any()).OrderBy(s => s.Name))
                        {
                            <div class="room-groups__item">
                                <span class="room-groups__dot @(root.IsPlaying ? "is-online" : "is-unknown")" aria-hidden="true"></span>
                                <strong>@root.Name</strong>
                                <span>@string.Join(", ", root.GroupMembers)</span>
                                <span class="badge rounded-pill text-uppercase @(root.IsPlaying ? "text-bg-success" : "text-bg-secondary")">
                                    @(root.IsPlaying ? "Playing" : "Paused")
                                </span>
                            </div>
                        }
                    </div>
                }
            </section>
        }

        <section class="library home-quick-library" aria-label="Favourite and recent sources">
            <header class="library__head">
                <div>
                    <span class="home-eyebrow">Quick access</span>
                    <h2>Favourites</h2>
                </div>
                <a class="btn btn-sm btn-outline-secondary" href="/library">
                    <span>View library</span>
                </a>
            </header>

            <div class="library__list">
                @if (libraryItems.Any())
                {
                    @foreach (var item in libraryItems)
                    {
                        <div class="library__item">
                            <span class="library__item-icon"><Icon Name="@GetMediaIcon(item.MediaType)" Size="15" /></span>
                            <div class="library__item-meta">
                                <strong title="@item.Name">@item.Name</strong>
                                @if (item.IsFavourite)
                                {
                                    <span>@FormatMediaTypeLabel(item.MediaType)</span>
                                }
                                else
                                {
                                    <span class="library__suggested">Suggested · @FormatMediaTypeLabel(item.MediaType)</span>
                                }
                            </div>
                            <button class="btn btn-sm btn-primary library__play" @onclick="() => PlayMediaItem(item.Url, item.MediaType)" aria-label="@($"Play {item.Name}")" disabled="@(_loadingMediaUrl == item.Url)">
                                @if (_loadingMediaUrl == item.Url) { <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> }
                                else { <Icon Name="play" Size="13" /> }
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="library__empty">No saved sources yet. Add one in Library.</div>
                }
            </div>
        </section>

        <div class="home-footer">
            <SectionCard Title="Active Automation" Eyebrow="Schedule" Icon="schedule" Id="home-automation-card">
                <HeaderExtras>
                    <a class="btn btn-sm btn-outline-secondary" href="/automation?tab=schedules">View schedules</a>
                </HeaderExtras>
                <ChildContent>
                <div class="home-window @(activeWindow is null ? "is-idle" : "")">
                    <div>
                        <h4>@(activeWindow?.Name ?? "Manual control")</h4>
                        <p>@GetActiveAutomationDescription(activeWindow, activeScene)</p>
                        @if (activeWindow is not null)
                        {
                            <div class="home-chips">
                                <span class="home-chip">Scene: @(activeScene?.Name ?? "None")</span>
                                <span class="home-chip">Fade @activeWindow.FadeOutSeconds</span>
                                <span class="home-chip">@GetSpeakerTargetSummary(activeScene)</span>
                            </div>
                        }
                    </div>
                    <div class="home-handoff">
                        <strong>@GetAutomationHandoffLabel(activeWindow, nowLocal)</strong>
                        <span>@(activeWindow is null ? "no active window" : "until handoff")</span>
                    </div>
                </div>
                @if (nextWindow is not null)
                {
                    <div class="home-next">
                        <time>@nextWindow.StartTime.ToString("HH\\:mm")</time>
                        <div>
                            <strong>@nextWindow.Name</strong>
                            <span>@GetSceneName(nextWindow.SceneId) · @GetWindowTimeRange(nextWindow)</span>
                        </div>
                        <span class="home-next__badge">Next</span>
                    </div>
                }
                </ChildContent>
            </SectionCard>

            <SectionCard Title="Device warnings" Eyebrow="Rooms" Icon="alert" Id="home-device-warnings-card">
                <ChildContent>
                @{ var deviceWarnings = _settings.Speakers.Where(speaker => !healthSummary.ByIp.TryGetValue(speaker.IpAddress, out var state) || !state.IsOnline).ToList(); }
                @if (deviceWarnings.Any())
                {
                    <ul class="home-activity">
                        @foreach (var speaker in deviceWarnings)
                        {
                            <li class="home-activity__row">
                                <div>
                                    <strong>@speaker.Name</strong>
                                    <span>@(healthSummary.ByIp.ContainsKey(speaker.IpAddress) ? "Offline" : "No health snapshot") · @speaker.IpAddress</span>
                                </div>
                                <Icon Name="alert" Size="17" />
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="library__empty">All configured rooms are reporting normally.</div>
                }
                </ChildContent>
            </SectionCard>
        </div>
    </div>
}

@code {
    public class SpeakerStatusViewModel
    {
        public string? Name { get; set; }
        public string? IpAddress { get; set; }
        public string? Uuid { get; set; }
        public bool IsPlaying { get; set; }
        public string? Media { get; set; }
        public string? MasterUuid { get; set; }
        public string? RawStationUrl { get; set; }
        public List<string> GroupMembers { get; set; } = new();
    }

    private const int FastRefreshIntervalSeconds = 3;
    private const int DefaultSlowLaneSeconds = 15;
    private const int QueuePageSize = 30;
    private static readonly int[] _queueRefreshOptions = new[] { 15, 30, 60 };

    private readonly object _refreshSync = new();
    private readonly SemaphoreSlim _refreshLoopLock = new(1, 1);
    private CancellationTokenSource _disposeCts = new();
    private CancellationTokenSource? _activeRefreshCts;
    private bool _refreshPending;
    private bool _refreshPendingSlowLane;
    private DateTime? _lastSuccessfulRefreshUtc;
    private DateTime? _lastSlowLaneRefreshUtc;
    private int _consecutiveRefreshFailures;
    private bool _isRefreshRunning;

    private readonly SemaphoreSlim _queueRefreshLock = new(1, 1);
    private CancellationTokenSource? _queueRefreshCts;
    private Timer? _queueRefreshTimer;
    private IReadOnlyList<SonosQueueItem> _queueItems = Array.Empty<SonosQueueItem>();
    private bool _isQueueLoading;
    private bool _queueAutoRefreshEnabled = true;
    private int _queueRefreshIntervalSeconds = 30;
    private int _queueStartIndex;
    private int _queueTotalMatches;
    private string? _queueErrorMessage;
    private string? _commandStatusMessage;
    private bool _commandStatusIsError;
    private CancellationTokenSource? _commandStatusCts;
    private bool _hasActiveQueueTransport;

    private List<SpeakerStatusViewModel> _speakerStatuses = new();
    private SonosSettings? _settings;
    private bool _playbackStateSubscribed;
    private bool _isPlaying;
    private bool _isGrouping;
    private bool _isUngrouping;
    private bool isGroupModalOpen;
    private bool _isDirectUrlLoading;
    private string? _loadingMediaUrl;
    private string _directMediaUrl = string.Empty;
    private string? _activeYouTubeToolbarUrl;

    private string SelectedSpeakerIp => PlaybackState.ActiveSpeakerIp;

    private string Greeting => AppTimeZone.Now.Hour switch
    {
        >= 5 and < 12 => "Good morning",
        >= 12 and < 18 => "Good afternoon",
        _ => "Good evening"
    };

    private Task SetActiveSpeaker(string ip) => PlaybackState.SetActiveSpeakerAsync(ip);
    private Task SetActiveVolume(int volume) => PlaybackState.SetVolumeAsync(volume);
    private Task TogglePlayback() => PlaybackState.TogglePlaybackAsync();

    // Quick Source add buttons reuse the same modal and set the target collection here.
    private string _activeMediaTab = "stations";
    private static readonly string[] _libraryTabs = ["stations", "spotify", "youtube", "youtubemusic"];
    private ElementReference _stationsTab;
    private ElementReference _spotifyTab;
    private ElementReference _youtubeTab;
    private ElementReference _youtubeMusicTab;
    private string _activeLibraryTab = "all";
    private string _librarySearch = string.Empty;
    private AddMediaItemModal _addMediaItemModal = default!;
    private string? _addModalError;


    private int MaxVolumeLimit => Math.Clamp(_settings?.MaxVolume ?? 100, 0, 100);

    private bool isAuthenticated;

    private bool isTimerModalOpen;
    private int timerMinutes = 60;
    private string? timerSelection;
    private string? timerErrorMessage;
    private CancellationTokenSource? _playbackTimerCts;
    private DateTime? _timerEndTimeUtc;
    private string? _timerSelectionName;

    private string currentStationUrl = "Loading...";
    private string currentlyPlaying = "Loading...";
    private string trackProgress = "";
    private Timer? _stationUpdateTimer;

    private bool QueueHasMore => _queueStartIndex < _queueTotalMatches;
    private bool IsRefreshStale => _consecutiveRefreshFailures >= 2;
    private int SlowLaneSeconds => Math.Clamp(Configuration.GetValue<int?>("Dashboard:SlowLaneSeconds") ?? DefaultSlowLaneSeconds, 10, 120);
    private string RefreshTelemetryLabel
    {
        get
        {
            if (_isRefreshRunning)
            {
                return "Syncing live state...";
            }

            if (!_lastSuccessfulRefreshUtc.HasValue)
            {
                return "Waiting for first successful refresh";
            }

            var elapsed = DateTime.UtcNow - _lastSuccessfulRefreshUtc.Value;
            if (elapsed.TotalSeconds < 5)
            {
                return "Updated just now";
            }

            return $"Last update {Math.Round(elapsed.TotalSeconds)}s ago";
        }
    }

    private List<TuneInStation> _stations =>
        (_settings?.Stations ?? new List<TuneInStation>())
        .OrderBy(s => s.Name)
        .ToList();

    private List<SpotifyObject> _tracks =>
        (_settings?.SpotifyTracks ?? new List<SpotifyObject>())
        .OrderBy(t => t.Name)
        .ToList();

    private List<YouTubeObject> _youTubeVideos =>
        (_settings?.YouTubeCollections ?? new List<YouTubeObject>())
        .OrderBy(t => t.Name)
        .ToList();

    private List<YouTubeMusicObject> _youTubeCollections =>
        (_settings?.YouTubeMusicCollections ?? new List<YouTubeMusicObject>())
        .OrderBy(t => t.Name)
        .ToList();

    private sealed record DashboardRecommendation(string Name, string Url, string MediaType);
    private IReadOnlyList<HomeLibrarySource> _homeLibraryItems = Array.Empty<HomeLibrarySource>();

    private sealed record DeviceHealthSummary(
        int Online,
        int Offline,
        int Unknown,
        IReadOnlyDictionary<string, DeviceHealthStatus> ByIp);

    private Scene? GetScene(string? sceneId)
    {
        if (string.IsNullOrWhiteSpace(sceneId))
        {
            return null;
        }

        return _settings?.Scenes?.FirstOrDefault(scene => string.Equals(scene.Id, sceneId, StringComparison.OrdinalIgnoreCase));
    }

    private string GetSceneName(string? sceneId)
        => GetScene(sceneId)?.Name ?? "No scene";

    private static string GetWindowTimeRange(ScheduleWindow window)
        => $"{window.StartTime:HH\\:mm}-{window.StopTime:HH\\:mm}";

    private string GetActiveAutomationDescription(ScheduleWindow? window, Scene? scene)
    {
        if (window is null)
        {
            return "No schedule window is active right now. Playback is under manual control.";
        }

        var sceneName = scene?.Name ?? "No linked scene";
        return $"Scene \"{sceneName}\" is active from {GetWindowTimeRange(window)} with synced room state visible here.";
    }

    private string GetSpeakerTargetSummary(Scene? scene)
    {
        if (scene?.SpeakerIps?.Any() != true && scene?.Actions?.Any(a => a.IncludeInPlayback) != true)
        {
            return "Rooms: auto";
        }

        var speakerIps = scene.SpeakerIps.Any()
            ? scene.SpeakerIps
            : scene.Actions.Where(action => action.IncludeInPlayback).Select(action => action.SpeakerIp).ToList();

        return $"{speakerIps.Count} room{(speakerIps.Count == 1 ? "" : "s")}";
    }

    private static string GetAutomationHandoffLabel(ScheduleWindow? window, DateTimeOffset nowLocal)
    {
        if (window is null)
        {
            return "Idle";
        }

        var now = TimeOnly.FromDateTime(nowLocal.DateTime);
        var stopDateTime = nowLocal.Date + window.StopTime.ToTimeSpan();
        if (window.StopTime <= window.StartTime && now >= window.StartTime)
        {
            stopDateTime = stopDateTime.AddDays(1);
        }

        var remaining = stopDateTime - nowLocal.DateTime;
        if (remaining <= TimeSpan.Zero)
        {
            return "Soon";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
        }

        return $"{Math.Max(1, remaining.Minutes)}m";
    }

    private ScheduleWindow? GetNextScheduleWindow(DateTimeOffset nowLocal, ScheduleWindow? activeWindow)
    {
        if (_settings?.ScheduleWindows is null)
        {
            return null;
        }

        return _settings.ScheduleWindows
            .Where(window => window.IsEnabled)
            .Where(window => activeWindow is null || !string.Equals(window.Id, activeWindow.Id, StringComparison.OrdinalIgnoreCase))
            .Select(window => new { Window = window, NextStart = GetNextStart(window, nowLocal) })
            .Where(item => item.NextStart is not null)
            .OrderBy(item => item.NextStart)
            .ThenBy(item => item.Window.Priority)
            .Select(item => item.Window)
            .FirstOrDefault();
    }

    private DateTimeOffset? GetNextStart(ScheduleWindow window, DateTimeOffset nowLocal)
    {
        for (var dayOffset = 0; dayOffset <= 7; dayOffset++)
        {
            var date = DateOnly.FromDateTime(nowLocal.DateTime.AddDays(dayOffset));
            if (!IsDateAllowedForDashboard(window, date.DayOfWeek))
            {
                continue;
            }

            if (window.ExcludedDates?.Contains(date) == true)
            {
                continue;
            }

            if (window.StartDate.HasValue && date < window.StartDate.Value)
            {
                continue;
            }

            if (window.EndDate.HasValue && date > window.EndDate.Value)
            {
                continue;
            }

            var candidate = date.ToDateTime(window.StartTime);
            if (candidate >= nowLocal.DateTime)
            {
                return AppTimeZone.FromLocal(candidate);
            }
        }

        return null;
    }

    private static bool IsDateAllowedForDashboard(ScheduleWindow window, DayOfWeek day)
    {
        return window.RecurrenceType switch
        {
            ScheduleRecurrenceType.Daily => true,
            ScheduleRecurrenceType.Weekdays => day is >= DayOfWeek.Monday and <= DayOfWeek.Friday,
            ScheduleRecurrenceType.Weekends => day is DayOfWeek.Saturday or DayOfWeek.Sunday,
            ScheduleRecurrenceType.CustomDays => window.DaysOfWeek?.Contains(day) == true,
            _ => false
        };
    }

    private static string GetWindowStatusLabel(ScheduleWindow window, ScheduleWindow? activeWindow)
        => activeWindow is not null && string.Equals(window.Id, activeWindow.Id, StringComparison.OrdinalIgnoreCase)
            ? "Active"
            : "Ready";

    private static string GetWindowStatusClass(ScheduleWindow window, ScheduleWindow? activeWindow)
        => activeWindow is not null && string.Equals(window.Id, activeWindow.Id, StringComparison.OrdinalIgnoreCase)
            ? "is-active"
            : "is-ready";

    private DeviceHealthSummary GetDeviceHealthSummary()
    {
        var snapshot = DeviceHealthSnapshotStore.GetSnapshot()
            .ToDictionary(status => status.SpeakerIp, StringComparer.OrdinalIgnoreCase);

        var speakers = _settings?.Speakers ?? new List<SonosSpeaker>();
        var online = speakers.Count(speaker => snapshot.TryGetValue(speaker.IpAddress, out var status) && status.IsOnline);
        var offline = speakers.Count(speaker => snapshot.TryGetValue(speaker.IpAddress, out var status) && !status.IsOnline);
        var unknown = Math.Max(0, speakers.Count - online - offline);

        return new DeviceHealthSummary(online, offline, unknown, snapshot);
    }

    private static string GetHealthClass(DeviceHealthStatus? status)
    {
        if (status is null)
        {
            return "is-unknown";
        }

        return status.IsOnline ? "is-online" : "is-offline";
    }

    private static string GetHealthMeta(DeviceHealthStatus? status)
    {
        if (status is null)
        {
            return "No snapshot";
        }

        if (!status.IsOnline)
        {
            return string.IsNullOrWhiteSpace(status.LastError) ? "Offline" : status.LastError;
        }

        return status.LastLatencyMs.HasValue ? $"Online · {status.LastLatencyMs.Value} ms" : "Online";
    }

    private IEnumerable<DashboardRecommendation> GetActiveLibrarySources()
    {
        IEnumerable<DashboardRecommendation> sources = _activeLibraryTab switch
        {
            "spotify" => (_settings?.SpotifyTracks ?? new List<SpotifyObject>())
                .OrderBy(track => track.Name)
                .Select(track => new DashboardRecommendation(track.Name, track.Url, "spotify")),
            "youtube" => (_settings?.YouTubeCollections ?? new List<YouTubeObject>())
                .OrderBy(video => video.Name)
                .Select(video => new DashboardRecommendation(video.Name, video.Url, "youtube")),
            "youtubemusic" => (_settings?.YouTubeMusicCollections ?? new List<YouTubeMusicObject>())
                .OrderBy(collection => collection.Name)
                .Select(collection => new DashboardRecommendation(collection.Name, collection.Url, "youtubemusic")),
            "stations" => (_settings?.Stations ?? new List<TuneInStation>())
                .OrderBy(station => station.Name)
                .Select(station => new DashboardRecommendation(station.Name, station.Url, "station")),
            _ => CombineAllLibrarySources()
        };

        if (string.IsNullOrWhiteSpace(_librarySearch))
        {
            return sources;
        }

        return sources.Where(source =>
            source.Name.Contains(_librarySearch, StringComparison.OrdinalIgnoreCase) ||
            source.Url.Contains(_librarySearch, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<DashboardRecommendation> CombineAllLibrarySources()
    {
        var stations = (_settings?.Stations ?? new List<TuneInStation>())
            .OrderBy(station => station.Name)
            .Select(station => new DashboardRecommendation(station.Name, station.Url, "station"));
        var spotify = (_settings?.SpotifyTracks ?? new List<SpotifyObject>())
            .OrderBy(track => track.Name)
            .Select(track => new DashboardRecommendation(track.Name, track.Url, "spotify"));
        var youtube = (_settings?.YouTubeCollections ?? new List<YouTubeObject>())
            .OrderBy(video => video.Name)
            .Select(video => new DashboardRecommendation(video.Name, video.Url, "youtube"));
        var ytmusic = (_settings?.YouTubeMusicCollections ?? new List<YouTubeMusicObject>())
            .OrderBy(collection => collection.Name)
            .Select(collection => new DashboardRecommendation(collection.Name, collection.Url, "youtubemusic"));

        return stations.Concat(spotify).Concat(youtube).Concat(ytmusic);
    }

    private List<YouTubeObject> GetVisibleYouTubeEntries()
    {
        var entries = (_settings?.YouTubeCollections ?? new List<YouTubeObject>())
            .OrderBy(video => video.Name)
            .ToList();

        if (string.IsNullOrWhiteSpace(_librarySearch))
        {
            return entries;
        }

        return entries
            .Where(entry =>
                entry.Name.Contains(_librarySearch, StringComparison.OrdinalIgnoreCase) ||
                entry.Url.Contains(_librarySearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private YouTubeObject? GetActiveToolbarYouTubeEntry()
    {
        if (!IsLibraryTabActive("youtube"))
        {
            return null;
        }

        var visibleEntries = GetVisibleYouTubeEntries();
        if (visibleEntries.Count == 0)
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(_activeYouTubeToolbarUrl))
        {
            var selectedEntry = visibleEntries.FirstOrDefault(entry =>
                string.Equals(entry.Url, _activeYouTubeToolbarUrl, StringComparison.OrdinalIgnoreCase));
            if (selectedEntry is not null)
            {
                return selectedEntry;
            }
        }

        var fallbackEntry = visibleEntries[0];
        _activeYouTubeToolbarUrl = fallbackEntry.Url;
        return fallbackEntry;
    }

    private void SetActiveYouTubeToolbarEntry(string? url)
    {
        _activeYouTubeToolbarUrl = string.IsNullOrWhiteSpace(url) ? null : url.Trim();
    }

    private bool IsLibraryTabActive(string tab) => string.Equals(_activeLibraryTab, tab, StringComparison.OrdinalIgnoreCase);

    private string GetLibraryTabClass(string tab) => IsLibraryTabActive(tab)
        ? "home-ops-library-tab is-active"
        : "home-ops-library-tab";

    private string GetLibraryTabIndex(string tab) => IsLibraryTabActive(tab) ? "0" : "-1";

    private string GetActiveLibraryTabId() => $"home-library-tab-{GetLibraryTabIdSuffix(_activeLibraryTab)}";

    private static string GetLibraryTabIdSuffix(string tab)
        => string.Equals(tab, "youtubemusic", StringComparison.OrdinalIgnoreCase) ? "youtube-music" : tab;

    private void SetLibraryTab(string tab)
    {
        if (!IsLibraryTabActive(tab))
        {
            _activeLibraryTab = tab;
            _librarySearch = string.Empty;

            if (!string.Equals(tab, "youtube", StringComparison.OrdinalIgnoreCase))
            {
                _activeYouTubeToolbarUrl = null;
            }
        }
    }

    private async Task HandleLibraryTabKeyDown(KeyboardEventArgs args, string currentTab)
    {
        var currentIndex = Array.FindIndex(_libraryTabs, tab => string.Equals(tab, currentTab, StringComparison.OrdinalIgnoreCase));
        if (currentIndex < 0)
        {
            return;
        }

        var nextIndex = args.Key switch
        {
            "ArrowRight" or "ArrowDown" => (currentIndex + 1) % _libraryTabs.Length,
            "ArrowLeft" or "ArrowUp" => (currentIndex - 1 + _libraryTabs.Length) % _libraryTabs.Length,
            "Home" => 0,
            "End" => _libraryTabs.Length - 1,
            _ => currentIndex
        };

        if (nextIndex != currentIndex)
        {
            var nextTab = _libraryTabs[nextIndex];
            SetLibraryTab(nextTab);
            await GetLibraryTabReference(nextTab).FocusAsync();
        }
    }

    private ElementReference GetLibraryTabReference(string tab) => tab switch
    {
        "spotify" => _spotifyTab,
        "youtube" => _youtubeTab,
        "youtubemusic" => _youtubeMusicTab,
        _ => _stationsTab
    };

