@page "/"
@using System.Text.RegularExpressions
@using System.Linq
@using Radzen.Blazor.Rendering
@using SonosControl.DAL.Interfaces
@using SonosControl.DAL.Models
@using SonosControl.Web.Data
@using SonosControl.Web.Models
@using SonosControl.Web.Pages.Index.Components
@using SonosControl.Web.Services
@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject INotificationService NotificationService
@inject IConfiguration Configuration
@inject ILogger<IndexPage> Logger
@inject IMetricsCollector MetricsCollector
@attribute [Authorize(Roles = "admin,operator,superadmin")]

<PageTitle>Sonos Control</PageTitle>

@if (_settings is not null)
{
    <div class="container dashboard-shell">
        <section class="broadcast-shell">
            <header class="broadcast-hero">
                <div class="broadcast-hero__copy">
                    <span class="broadcast-kicker">
                        <AppIcon Name="signal" Size="16" />
                        Live command deck
                    </span>
                    <h1 class="broadcast-hero__title">Sonos Broadcast Studio</h1>
                    <p class="broadcast-hero__summary">Command playback, coordinate linked rooms, and keep curated sources ready for air from one deliberate control surface.</p>
                </div>

                <div class="broadcast-hero__stats" aria-label="Dashboard telemetry">
                    <article class="broadcast-stat-card">
                        <span class="broadcast-stat-card__label">Active room</span>
                        <strong class="broadcast-stat-card__value">@ActiveSpeakerName</strong>
                        <span class="broadcast-stat-card__meta">@LiveStateLabel</span>
                    </article>
                    <article class="broadcast-stat-card">
                        <span class="broadcast-stat-card__label">Rooms online</span>
                        <strong class="broadcast-stat-card__value">@OnlineSpeakerCount/@(_settings.Speakers.Count)</strong>
                        <span class="broadcast-stat-card__meta">@GroupedSpeakerCount grouped</span>
                    </article>
                    <article class="broadcast-stat-card">
                        <span class="broadcast-stat-card__label">Source</span>
                        <strong class="broadcast-stat-card__value">@CurrentPlaybackSourceLabel</strong>
                        <span class="broadcast-stat-card__meta">@RefreshTelemetryLabel</span>
                    </article>
                </div>
            </header>

            <div class="broadcast-pulse-row">
                <span class="broadcast-pill @( _isPlaying ? "broadcast-pill--live" : "broadcast-pill--idle")">
                    <span class="broadcast-pill__dot"></span>
                    @LiveStateLabel
                </span>
                <span class="broadcast-pill @(IsRefreshStale ? "broadcast-pill--warn" : string.Empty)">
                    <AppIcon Name="refresh" Size="14" Class="@(_isRefreshRunning ? "broadcast-pill__icon--spinning" : string.Empty)" />
                    @RefreshTelemetryLabel
                </span>
                <span class="broadcast-pill">
                    <AppIcon Name="cast" Size="14" />
                    @GroupedSpeakerCount linked room@(GroupedSpeakerCount == 1 ? string.Empty : "s")
                </span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_commandStatusMessage))
            {
                <div class="broadcast-status-banner @(_commandStatusIsError ? "broadcast-status-banner--error" : string.Empty)" role="status" aria-live="polite">
                    <AppIcon Name="@(_commandStatusIsError ? "status" : "signal")" Size="18" />
                    <span>@_commandStatusMessage</span>
                </div>
            }

            <div class="broadcast-grid">
                <div class="broadcast-main-column">
                    <section class="dashboard-card command-deck" aria-labelledby="command-deck-heading">
                        <div class="dashboard-card__header dashboard-card__header--split">
                            <div>
                                <span class="dashboard-card__eyebrow">
                                    <AppIcon Name="dashboard" Size="16" />
                                    Routing and sync
                                </span>
                                <h2 id="command-deck-heading" class="dashboard-card__title">Command deck</h2>
                                <p class="dashboard-card__copy">Pick the room on air, then handle grouping, breakup, and synchronized playback from one control strip.</p>
                            </div>
                            <div class="command-deck__room-badge">
                                <span>Active room</span>
                                <strong>@ActiveSpeakerName</strong>
                            </div>
                        </div>

                        @if (_settings.Speakers.Any())
                        {
                            <div class="command-deck__controls">
                                <label for="activeSpeakerSelect" class="command-deck__label">Choose room</label>
                                <div class="command-deck__row">
                                    <select id="activeSpeakerSelect" class="form-select command-deck__select" @bind="SelectedSpeakerIp">
                                        @foreach (var speaker in _settings.Speakers)
                                        {
                                            <option value="@speaker.IpAddress">@speaker.Name</option>
                                        }
                                    </select>

                                    <div class="command-deck__actions">
                                        <button class="btn btn-outline-primary command-deck__action" @onclick="OpenGroupModal" disabled="@(_isGrouping || _isUngrouping)" title="Group speakers">
                                            @if (_isGrouping)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <AppIcon Name="link" Size="18" />
                                            }
                                            <span>Group</span>
                                        </button>
                                        <button class="btn btn-outline-secondary command-deck__action" @onclick="UngroupCurrent" disabled="@(_isGrouping || _isUngrouping)" title="Ungroup active speaker" aria-label="Ungroup active speaker">
                                            @if (_isUngrouping)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <AppIcon Name="unlink" Size="18" />
                                            }
                                            <span>Ungroup</span>
                                        </button>
                                        <button class="btn btn-primary command-deck__action command-deck__action--accent" @onclick="SyncPlay" disabled="@_isSyncing" title="Play current media on all speakers">
                                            @if (_isSyncing)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                <span class="visually-hidden">Syncing...</span>
                                            }
                                            else
                                            {
                                                <AppIcon Name="cast" Size="18" />
                                            }
                                            <span>Sync Play</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="dashboard-empty-state">
                                <AppIcon Name="speaker" Size="22" />
                                <div>
                                    <strong>No speakers connected</strong>
                                    <p class="mb-0">Add a room in configuration to start routing playback from the studio.</p>
                                </div>
                            </div>
                        }
                    </section>

                    <PlaybackCard
                        IsPlaying="_isPlaying"
                        IsLoading="_isMainPlaybackLoading"
                        ShowNextTrack="_isPlaying && _isSpotifyPlaying"
                        IsNextTrackLoading="_isNextTrackLoading"
                        Volume="Volume"
                        MaxVolumeLimit="MaxVolumeLimit"
                        GradientStyle="PlaybackCardStyle"
                        TogglePlay="Play"
                        VolumeChanged="@(value => Volume = value)"
                        OnOpenTimer="OpenTimerModal"
                        OnNextTrack="NextTrack" />

                    @if (_timerEndTimeUtc is not null)
                    {
                        var localStopTime = _timerEndTimeUtc.Value.ToLocalTime();
                        <section class="timer-callout" aria-live="polite">
                            <div class="timer-callout__icon">
                                <AppIcon Name="clock" Size="18" />
                            </div>
                            <div class="timer-callout__copy">
                                <strong>Timed playback armed</strong>
                                <p class="mb-0">@(_timerSelectionName ?? "Playback") stops at @localStopTime.ToString("t") for @ActiveSpeakerName.</p>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary timer-callout__action" @onclick="CancelTimedPlayback">Cancel timer</button>
                        </section>
                    }

                    <section class="dashboard-card now-playing-panel" aria-labelledby="now-playing-heading">
                        <div class="dashboard-card__header dashboard-card__header--split">
                            <div>
                                <span class="dashboard-card__eyebrow">
                                    <AppIcon Name="album" Size="16" />
                                    Live program
                                </span>
                                <h2 id="now-playing-heading" class="dashboard-card__title">Now Playing</h2>
                                <p class="dashboard-card__copy">Source metadata, artwork, and runtime for the room currently on air.</p>
                            </div>
                            <div class="now-playing-panel__badges">
                                <span class="now-playing-panel__chip">@CurrentPlaybackSourceLabel</span>
                                @if (!string.IsNullOrWhiteSpace(trackProgress))
                                {
                                    <span class="now-playing-panel__chip now-playing-panel__chip--muted">@trackProgress</span>
                                }
                            </div>
                        </div>

                        <div class="now-playing-panel__body">
                            <div class="now-playing-panel__art">
                                @if (!string.IsNullOrWhiteSpace(currentTrackArtUrl))
                                {
                                    <img src="@currentTrackArtUrl" alt="@($"Album art for {currentlyPlaying}")" class="now-playing-panel__image" />
                                }
                                else
                                {
                                    <div class="now-playing-panel__fallback" aria-hidden="true">
                                        <AppIcon Name="music" Size="30" />
                                    </div>
                                }
                            </div>

                            <div class="now-playing-panel__content">
                                <div class="now-playing-panel__headline">
                                    <span class="now-playing-panel__label">Track</span>
                                    <h3 class="now-playing-panel__track">@CurrentTrackLabel</h3>
                                </div>

                                <div class="now-playing-panel__details-grid">
                                    <div class="now-playing-panel__detail">
                                        <span class="now-playing-panel__label">Source</span>
                                        <strong>@CurrentPlaybackSourceLabel</strong>
                                    </div>
                                    <div class="now-playing-panel__detail">
                                        <span class="now-playing-panel__label">Room</span>
                                        <strong>@ActiveSpeakerName</strong>
                                    </div>
                                    <div class="now-playing-panel__detail now-playing-panel__detail--wide">
                                        <span class="now-playing-panel__label">Feed status</span>
                                        <strong>@(_isPlaying ? "Program is live." : "Playback is paused.")</strong>
                                    </div>
                                    <div class="now-playing-panel__detail">
                                        <span class="now-playing-panel__label">Refresh</span>
                                        <strong>@RefreshStatusLabel</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <QueuePanel
                        SpeakerName="@ActiveSpeakerName"
                        Items="_queueItems"
                        IsLoading="_isQueueLoading"
                        HasMore="QueueHasMore"
                        AutoRefreshEnabled="_queueAutoRefreshEnabled"
                        RefreshIntervalSeconds="_queueRefreshIntervalSeconds"
                        RefreshIntervals="_queueRefreshOptions"
                        ErrorMessage="@_queueErrorMessage"
                        Refresh="HandleQueueRefresh"
                        LoadMore="LoadMoreQueueItems"
                        AutoRefreshChanged="HandleQueueAutoRefreshChanged"
                        RefreshIntervalChanged="HandleQueueRefreshIntervalChanged"
                        FormatItem="FormatQueueItem" />
                </div>

                <aside class="broadcast-rail">
                    <section class="dashboard-card speaker-panel" aria-labelledby="speaker-panel-heading">
                        <div class="dashboard-card__header">
                            <span class="dashboard-card__eyebrow">
                                <AppIcon Name="speakers" Size="16" />
                                Room telemetry
                            </span>
                            <h2 id="speaker-panel-heading" class="dashboard-card__title">Speaker Status</h2>
                            <p class="dashboard-card__copy">See which rooms are live, linked to another room, or currently waiting off air.</p>
                        </div>

                        <ul class="speaker-roster">
                            @if (_speakerStatuses.Any())
                            {
                                var roots = _speakerStatuses
                                    .Where(s => string.IsNullOrEmpty(s.MasterUuid) || !_speakerStatuses.Any(m => m.Uuid == s.MasterUuid))
                                    .OrderBy(s => s.Name);

                                foreach (var root in roots)
                                {
                                    <li class="@GetSpeakerStatusClasses(root)">
                                        <div class="speaker-roster__content">
                                            <div class="speaker-roster__name-row">
                                                <span class="speaker-roster__indicator"></span>
                                                <div>
                                                    <strong class="speaker-roster__name">@root.Name</strong>
                                                    <p class="speaker-roster__meta mb-0">@GetSpeakerStatusDescription(root)</p>
                                                </div>
                                            </div>
                                            <span class="speaker-roster__state">@GetSpeakerStateLabel(root)</span>
                                        </div>
                                    </li>

                                    var children = _speakerStatuses.Where(s => s.MasterUuid == root.Uuid).OrderBy(s => s.Name);
                                    foreach (var child in children)
                                    {
                                        <li class="@GetSpeakerStatusClasses(child, isChild: true)">
                                            <div class="speaker-roster__content">
                                                <div class="speaker-roster__name-row">
                                                    <span class="speaker-roster__indicator"></span>
                                                    <div>
                                                        <strong class="speaker-roster__name">@child.Name</strong>
                                                        <p class="speaker-roster__meta mb-0">Linked to @root.Name</p>
                                                    </div>
                                                </div>
                                                <span class="speaker-roster__state">@GetSpeakerStateLabel(child)</span>
                                            </div>
                                        </li>
                                    }
                                }
                            }
                            else
                            {
                                <li class="speaker-roster__empty">No room telemetry is available yet.</li>
                            }
                        </ul>
                    </section>

                    <section class="dashboard-card library-panel" aria-labelledby="library-panel-heading">
                        <div class="dashboard-card__header">
                            <span class="dashboard-card__eyebrow">
                                <AppIcon Name="radio" Size="16" />
                                Source library
                            </span>
                            <h2 id="library-panel-heading" class="dashboard-card__title">Media Sources</h2>
                            <p class="dashboard-card__copy">Keep your fastest station, Spotify, and YouTube presets within easy reach for the next handoff.</p>
                        </div>

                        <MediaTabs @bind-ActiveTab="_activeMediaTab">
                            <StationsContent>
                                @{
                                    var stations = _stations;
                                    <div class="media-list-header">
                                        <div>
                                            <h3 class="media-list-header__title">Saved Stations</h3>
                                            <p class="media-list-header__copy">Quick-launch radio presets for room handoffs and daily programming.</p>
                                        </div>
                                        <div class="media-list-header__actions">
                                            <button class="btn btn-outline-secondary media-toolbar-btn" @onclick="ShuffleStation" title="Play random station" aria-label="Play random station" disabled="@_isShuffleLoading">
                                                @if (_isShuffleLoading)
                                                {
                                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                }
                                                else
                                                {
                                                    <AppIcon Name="shuffle" Size="16" />
                                                }
                                                <span>Shuffle</span>
                                            </button>
                                            <button class="btn btn-primary media-toolbar-btn" @onclick="ShowAddStationModal" aria-label="Add station">
                                                <AppIcon Name="plus" Size="16" />
                                                <span>Add</span>
                                            </button>
                                        </div>
                                    </div>
                                    <ul class="list-group media-list">
                                        @if (stations.Any())
                                        {
                                            @foreach (var station in stations)
                                            {
                                                <li class="list-group-item media-list__item @(IsCurrentlyPlaying(station.Url) ? "active-media" : string.Empty)">
                                                    <div class="media-list__body">
                                                        <span class="media-list__name">@station.Name</span>
                                                        <span class="media-list__meta">TuneIn preset</span>
                                                    </div>
                                                    <div class="media-list__actions">
                                                        <button class="btn btn-sm btn-success media-list__action-btn" @onclick="@(() => PlayMediaItem(station.Url, "station"))" aria-label="Play @station.Name" disabled="@(_loadingMediaUrl == station.Url)">
                                                            @if (_loadingMediaUrl == station.Url)
                                                            {
                                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                            }
                                                            else
                                                            {
                                                                <AppIcon Name="play" Size="16" />
                                                            }
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger media-list__action-btn" @onclick="@(() => RemoveStation(station))" aria-label="Remove @station.Name">
                                                            <AppIcon Name="trash" Size="16" />
                                                        </button>
                                                    </div>
                                                </li>
                                            }
                                        }
                                        else
                                        {
                                            <li class="list-group-item media-list__empty">No saved stations yet. Add one to keep broadcast handoffs fast.</li>
                                        }
                                    </ul>
                                }
                            </StationsContent>
                            <SpotifyContent>
                                @{
                                    var tracks = _tracks;
                                    <div class="media-list-header">
                                        <div>
                                            <h3 class="media-list-header__title">Saved Spotify</h3>
                                            <p class="media-list-header__copy">Playlist and album shortcuts ready to cue into the active room.</p>
                                        </div>
                                        <div class="media-list-header__actions">
                                            <button class="btn btn-primary media-toolbar-btn" @onclick="ShowAddSpotifyModal" aria-label="Add Spotify track">
                                                <AppIcon Name="plus" Size="16" />
                                                <span>Add</span>
                                            </button>
                                        </div>
                                    </div>
                                    <ul class="list-group media-list">
                                        @if (tracks.Any())
                                        {
                                            @foreach (var track in tracks)
                                            {
                                                <li class="list-group-item media-list__item @(IsCurrentlyPlaying(track.Url) ? "active-media" : string.Empty)">
                                                    <div class="media-list__body">
                                                        <span class="media-list__name">@track.Name</span>
                                                        <span class="media-list__meta">Spotify shortcut</span>
                                                    </div>
                                                    <div class="media-list__actions">
                                                        <button class="btn btn-sm btn-success media-list__action-btn" @onclick="@(() => PlayMediaItem(track.Url, "spotify"))" aria-label="Play @track.Name" disabled="@(_loadingMediaUrl == track.Url)">
                                                            @if (_loadingMediaUrl == track.Url)
                                                            {
                                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                            }
                                                            else
                                                            {
                                                                <AppIcon Name="play" Size="16" />
                                                            }
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger media-list__action-btn" @onclick="@(() => RemoveSpotifyTrack(track))" aria-label="Remove @track.Name">
                                                            <AppIcon Name="trash" Size="16" />
                                                        </button>
                                                    </div>
                                                </li>
                                            }
                                        }
                                        else
                                        {
                                            <li class="list-group-item media-list__empty">No Spotify shortcuts saved yet.</li>
                                        }
                                    </ul>
                                }
                            </SpotifyContent>
                            <YouTubeContent>
                                @{
                                    var collections = _youTubeCollections;
                                    <div class="media-list-header">
                                        <div>
                                            <h3 class="media-list-header__title">Saved YouTube Music</h3>
                                            <p class="media-list-header__copy">Ready-made YouTube collections for quick swaps between formats.</p>
                                        </div>
                                        <div class="media-list-header__actions">
                                            <button class="btn btn-primary media-toolbar-btn" @onclick="ShowAddYouTubeModal" aria-label="Add YouTube Music collection">
                                                <AppIcon Name="plus" Size="16" />
                                                <span>Add</span>
                                            </button>
                                        </div>
                                    </div>
                                    <ul class="list-group media-list">
                                        @if (collections.Any())
                                        {
                                            @foreach (var collection in collections)
                                            {
                                                <li class="list-group-item media-list__item @(IsCurrentlyPlaying(collection.Url) ? "active-media" : string.Empty)">
                                                    <div class="media-list__body">
                                                        <span class="media-list__name">@collection.Name</span>
                                                        <span class="media-list__meta">YouTube Music collection</span>
                                                    </div>
                                                    <div class="media-list__actions">
                                                        <button class="btn btn-sm btn-success media-list__action-btn" @onclick="@(() => PlayMediaItem(collection.Url, "youtube"))" aria-label="Play @collection.Name" disabled="@(_loadingMediaUrl == collection.Url)">
                                                            @if (_loadingMediaUrl == collection.Url)
                                                            {
                                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                            }
                                                            else
                                                            {
                                                                <AppIcon Name="play" Size="16" />
                                                            }
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger media-list__action-btn" @onclick="@(() => RemoveYouTubeMusicEntry(collection))" aria-label="Remove @collection.Name">
                                                            <AppIcon Name="trash" Size="16" />
                                                        </button>
                                                    </div>
                                                </li>
                                            }
                                        }
                                        else
                                        {
                                            <li class="list-group-item media-list__empty">No YouTube Music collections saved yet.</li>
                                        }
                                    </ul>
                                }
                            </YouTubeContent>
                        </MediaTabs>

                        <section class="direct-source-panel">
                            <div class="direct-source-panel__header">
                                <div>
                                    <span class="dashboard-card__eyebrow">
                                        <AppIcon Name="spotify" Size="16" />
                                        Direct source cue
                                    </span>
                                    <h3 class="direct-source-panel__title">Play Spotify URL</h3>
                                </div>
                            </div>
                            <div class="input-group direct-source-panel__input-group">
                                <input type="text"
                                       class="form-control"
                                       @bind-value="spotifyUrl"
                                       @bind-value:event="oninput"
                                       @onkeyup="HandleKeyPress"
                                       placeholder="Paste a Spotify URL to send live"
                                       aria-label="Spotify URL" />
                                <button class="btn btn-primary direct-source-panel__play" type="button" @onclick="SubmitSpotifyUrl" disabled="@_isSpotifyUrlLoading">
                                    @if (_isSpotifyUrlLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span class="visually-hidden">Loading...</span>
                                    }
                                    else
                                    {
                                        <AppIcon Name="play" Size="16" />
                                    }
                                    <span>Play</span>
                                </button>
                            </div>
                        </section>
                    </section>
                </aside>
            </div>
        </section>
    </div>
}

<TimerModal
    Show="isTimerModalOpen"
    OnClose="CloseTimerModal"
    OnStart="StartTimedPlayback"
    TimerMinutes="timerMinutes"
    TimerMinutesChanged="value => timerMinutes = value"
    SelectedSource="timerSelection"
    SelectedSourceChanged="value => timerSelection = value"
    Stations="_stations"
    SpotifyTracks="_tracks"
    YouTubeCollections="_youTubeCollections"
    ErrorMessage="@timerErrorMessage" />

<AddMediaItemModal @ref="_addMediaItemModal" OnSave="SaveNewMediaItem" ErrorMessage="@_addModalError" OnClose="() => _addModalError = null"/>

<GroupSpeakersModal Show="isGroupModalOpen"
                    Speakers="@(_settings?.Speakers ?? new())"
                    MasterIp="@SelectedSpeakerIp"
                    IsLoading="@_isGrouping"
                    OnClose="CloseGroupModal"
                    OnGroup="HandleCreateGroup" />

@code {
    public class SpeakerStatusViewModel
    {
        public string? Name { get; set; }
        public string? IpAddress { get; set; }
        public string? Uuid { get; set; }
        public bool IsPlaying { get; set; }
        public string? Media { get; set; }
        public string? MasterUuid { get; set; }
        public string? RawStationUrl { get; set; }
    }

    private const int FastRefreshIntervalSeconds = 3;
    private const int DefaultSlowLaneSeconds = 15;
    private const int QueuePageSize = 30;
    private static readonly int[] _queueRefreshOptions = new[] { 15, 30, 60 };

    private readonly object _refreshSync = new();
    private readonly SemaphoreSlim _refreshLoopLock = new(1, 1);
    private CancellationTokenSource _disposeCts = new();
    private CancellationTokenSource? _activeRefreshCts;
    private bool _refreshPending;
    private bool _refreshPendingSlowLane;
    private DateTime? _lastSuccessfulRefreshUtc;
    private DateTime? _lastSlowLaneRefreshUtc;
    private int _consecutiveRefreshFailures;
    private bool _isRefreshRunning;

    private readonly SemaphoreSlim _queueRefreshLock = new(1, 1);
    private CancellationTokenSource? _queueRefreshCts;
    private Timer? _queueRefreshTimer;
    private IReadOnlyList<SonosQueueItem> _queueItems = Array.Empty<SonosQueueItem>();
    private bool _isQueueLoading;
    private bool _queueAutoRefreshEnabled = true;
    private int _queueRefreshIntervalSeconds = 30;
    private int _queueStartIndex;
    private int _queueTotalMatches;
    private string? _queueErrorMessage;
    private string? _commandStatusMessage;
    private bool _commandStatusIsError;
    private CancellationTokenSource? _commandStatusCts;

    private List<SpeakerStatusViewModel> _speakerStatuses = new();
    private SonosSettings? _settings;
    private bool _isPlaying;
    private bool _isSyncing;
    private bool _isGrouping;
    private bool _isUngrouping;
    private bool isGroupModalOpen;
    private bool _isMainPlaybackLoading;
    private bool _isNextTrackLoading;
    private bool _isSpotifyUrlLoading;
    private string? _loadingMediaUrl;
    private bool _isSpotifyPlaying;
    private string? spotifyUrl;
    private string? _selectedSpeakerIp;

    private string SelectedSpeakerIp
    {
        get => _selectedSpeakerIp ?? _settings?.IP_Adress ?? "";
        set
        {
            if (_selectedSpeakerIp != value)
            { 
                _selectedSpeakerIp = value;
                if (_settings != null)
                {
                    _ = UpdateSpeakerRelatedData(value);
                }
            }
        }
    }

    private async Task UpdateSpeakerRelatedData(string newIpAddress)
    {
        if (_settings is null)
        {
            return;
        }

        _settings.IP_Adress = newIpAddress;
        await SaveSettings();

        try
        {
            _settings.Volume = await _uow.ISonosConnectorRepo.GetVolume(newIpAddress);
        }
        catch
        {
            // Ignore if speaker is offline or returns error
            _settings.Volume = 0; // Default to 0 or last known good if error
        }

        // Refresh data for the new speaker
        await RequestPageRefreshAsync(forceSlowLane: true);
        await RefreshQueueAsync(reset: true);
    }

