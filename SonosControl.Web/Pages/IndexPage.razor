    private static string GetLibraryTabForMediaType(string mediaType)
        => string.Equals(mediaType, "station", StringComparison.OrdinalIgnoreCase) ? "stations" : mediaType;

    private static string GetAddModalTitle(string activeMediaTab)
    {
        return activeMediaTab switch
        {
            "spotify" => "Add New Spotify Item",
            "youtube" => "Add New YouTube Video",
            "youtubemusic" => "Add New YouTube Music Item",
            _ => "Add New Station"
        };
    }

    private void ShowAddStationModal()
