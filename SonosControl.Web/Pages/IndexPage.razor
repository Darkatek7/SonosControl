        _addMediaItemModal.Show(GetAddModalTitle(_activeMediaTab));
    }

    private void ShowAddYouTubeModal()
    {
        _activeMediaTab = "youtube";
        _addMediaItemModal.Show(GetAddModalTitle(_activeMediaTab));
