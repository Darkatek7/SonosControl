    private async Task PlayDirectMediaUrl()
    {
        var resolution = DirectUrlMediaResolver.Resolve(_directMediaUrl);
        if (!resolution.IsValid)
        {
            ShowCommandStatus(resolution.ErrorMessage ?? "The media URL is invalid.", isError: true, autoHideMs: 4500);
            return;
        }

        _isDirectUrlLoading = true;
        await InvokeAsync(StateHasChanged);

