@using SonosControl.Web.Services
@using SonosControl.Web.Shared
@implements IDisposable
@inject PlaybackUiStateService PlaybackState

<section class="np-hero @(HasArt ? "np-hero--has-art" : "np-hero--no-art")"
         data-qa="now-playing-hero" aria-labelledby="now-playing-hero-title">
    <div class="np-hero__art" aria-hidden="true">
        @if (HasArt)
        {
            <img src="@PlaybackState.CurrentTrackArtUrl" alt="" />
        }
        else
        {
            <div class="np-hero__art-fallback">
                <span class="np-hero__record-kicker">Sonos live</span>
                <div class="np-hero__record-stage">
                    <div class="np-hero__record @(PlaybackState.IsPlaying ? "is-spinning" : null)">
                        <div class="np-hero__record-label">
                            <span class="np-hero__record-brand">SC</span>
                            <span class="np-hero__record-imprint" aria-hidden="true">
                                <Icon Name="music" Size="17" />
                            </span>
                        </div>
                    </div>
                </div>
                <span class="np-hero__record-caption">No artwork · still spinning</span>
            </div>
        }
    </div>

    <div class="np-hero__content">
        <div class="np-hero__status-line">
            <span class="np-hero__eyebrow">Now Playing</span>
            <span class="np-hero__playback-state @(PlaybackState.IsPlaying ? "is-playing" : "is-paused")">
                <span aria-hidden="true"></span>
                @(PlaybackState.IsPlaying ? "Playing" : "Paused")
            </span>
        </div>

        <div class="np-hero__meta">
            <h2 class="np-hero__title" id="now-playing-hero-title">@PlaybackState.CurrentTrack</h2>
            <p class="np-hero__source">@PlaybackState.CurrentStationDisplay</p>
        </div>

        <div class="np-hero__room">
            <label for="home-now-playing-room">Active room</label>
            <select id="home-now-playing-room"
                    class="form-select"
                    value="@PlaybackState.ActiveSpeakerIp"
                    @onchange="HandleSpeakerChanged">
                @foreach (var speaker in PlaybackState.Speakers)
                {
                    <option value="@speaker.IpAddress">@speaker.Name</option>
                }
            </select>
        </div>

        <div class="np-hero__transport" aria-label="Playback controls">
            <button type="button" class="np-hero__btn"
                    data-qa="home-player-refresh"
                    @onclick="Refresh" disabled="@PlaybackState.IsLoading"
                    aria-label="Refresh playback state">
                <Icon Name="refresh" Size="18" Class="@(PlaybackState.IsLoading ? "icon-spin" : "")" />
            </button>
            <button type="button" class="np-hero__play"
                    data-qa="home-player-toggle"
                    @onclick="Toggle" disabled="@PlaybackState.IsLoading"
                    aria-label="@(PlaybackState.IsPlaying ? "Pause playback" : "Start playback")">
                @if (PlaybackState.IsLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <Icon Name="@(PlaybackState.IsPlaying ? "pause" : "play")" Size="22" />
                }
            </button>
            <button type="button" class="np-hero__btn"
                    data-qa="home-player-next"
                    @onclick="Skip" disabled="@(PlaybackState.IsLoading || PlaybackState.IsSkipping)"
                    aria-label="Next track">
                @if (PlaybackState.IsSkipping)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <Icon Name="forward" Size="18" />
                }
            </button>
        </div>

        <div class="np-hero__volume">
            <span class="np-hero__volume-label"><Icon Name="volume" Size="16" /> Volume</span>
            <VolumeControl Value="@PlaybackState.Volume"
                           MaxVolume="@PlaybackState.MaxVolume"
                           ValueChanged="PlaybackState.SetVolumeAsync"
                           IdPrefix="home-now-playing-volume"
                           Label="Volume for active room" />
        </div>
    </div>
</section>

@code {
    private bool HasArt => !string.IsNullOrWhiteSpace(PlaybackState.CurrentTrackArtUrl);

    protected override void OnInitialized()
    {
        PlaybackState.StateChanged += OnChanged;
    }

    private void OnChanged() => _ = InvokeAsync(StateHasChanged);

    private Task Refresh() => PlaybackState.RefreshAsync();
    private Task Toggle() => PlaybackState.TogglePlaybackAsync();
    private Task Skip() => PlaybackState.SkipNextAsync();

    private Task HandleSpeakerChanged(ChangeEventArgs args)
        => args.Value is string speakerIp
            ? PlaybackState.SetActiveSpeakerAsync(speakerIp)
            : Task.CompletedTask;

    public void Dispose() => PlaybackState.StateChanged -= OnChanged;
}
