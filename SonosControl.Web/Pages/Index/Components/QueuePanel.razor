@using System
@using Microsoft.AspNetCore.Components
@using SonosControl.DAL.Models

<div class="card queue-panel" data-qa="queue-card">
    <div class="card-header queue-panel__header">
        <div class="queue-panel__title-group">
            <span class="queue-panel__eyebrow">
                <AppIcon Name="queue" Size="16" />
                Program stack
            </span>
            <div>
                <h5 class="mb-1">Playback Queue</h5>
                <p class="queue-panel__subtitle mb-0">@QueueSubtitle</p>
            </div>
        </div>
        <div class="queue-panel__toolbar">
            <div class="queue-panel__toolbar-group">
                <label class="form-label small mb-0 text-muted" for="@RefreshSelectId">Refresh every</label>
                <select id="@RefreshSelectId"
                        class="form-select form-select-sm queue-panel__select"
                        value="@RefreshIntervalSeconds"
                        @onchange="HandleIntervalChange"
                        aria-label="Queue auto refresh interval">
                    @foreach (var option in RefreshIntervals)
                    {
                        <option value="@option">@option s</option>
                    }
                </select>
            </div>
            <div class="form-check form-switch m-0 queue-panel__switch">
                <input class="form-check-input"
                       type="checkbox"
                       role="switch"
                       id="queueAutoRefreshSwitch"
                       @bind="AutoRefreshEnabledValue"
                       aria-label="Toggle queue auto refresh" />
                <label class="form-check-label small" for="queueAutoRefreshSwitch">Auto</label>
            </div>
            <button class="btn btn-outline-secondary btn-sm queue-panel__refresh"
                    @onclick="Refresh"
                    disabled="@IsLoading"
                    aria-label="Refresh queue now">
                <AppIcon Name="refresh" Size="16" Class="@(IsLoading ? "queue-panel__refresh-icon queue-panel__refresh-icon--spinning" : "queue-panel__refresh-icon")" />
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="card-body queue-panel__body">
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-warning queue-panel__status" role="alert">@ErrorMessage</div>
        }
        else if (IsLoading && Items.Count == 0)
        {
            <div class="queue-panel__empty-state" role="status" aria-live="polite">
                <div class="queue-panel__empty-visual">
                    <span class="queue-panel__skeleton queue-panel__skeleton--wide"></span>
                    <span class="queue-panel__skeleton"></span>
                    <span class="queue-panel__skeleton queue-panel__skeleton--short"></span>
                </div>
                <p class="queue-panel__empty-title mb-1">Loading queue telemetry</p>
                <p class="queue-panel__empty-copy mb-0">Pulling the current stack from @QueueContextLabel.</p>
            </div>
        }
        else if (Items.Count == 0)
        {
            <div class="queue-panel__empty-state">
                <AppIcon Name="music" Size="24" Class="queue-panel__empty-icon" />
                <p class="queue-panel__empty-title mb-1">Queue is clear</p>
                <p class="queue-panel__empty-copy mb-0">Send a station, playlist, or collection to @QueueContextLabel to build the next rundown.</p>
            </div>
        }
        else
        {
            <ul class="list-group queue-panel__list">
                @foreach (var item in Items)
                {
                    <li class="list-group-item queue-panel__item @(item.Index == 0 ? "queue-panel__item--lead" : string.Empty)">
                        <span class="queue-panel__order">@((item.Index + 1).ToString("D2"))</span>
                        <div class="queue-panel__item-body">
                            <div class="queue-panel__item-title">@FormatItem?.Invoke(item)</div>
                            @if (!string.IsNullOrWhiteSpace(item.Album))
                            {
                                <div class="queue-panel__item-meta">@item.Album</div>
                            }
                        </div>
                        @if (item.Index == 0)
                        {
                            <span class="queue-panel__flag">Next</span>
                        }
                    </li>
                }
            </ul>

            @if (HasMore)
            {
                <div class="text-center mt-3">
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="LoadMore"
                            disabled="@IsLoading"
                            aria-label="Load more queue items">
                        @(IsLoading ? "Loading…" : "Load more")
                    </button>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<SonosQueueItem> Items { get; set; } = Array.Empty<SonosQueueItem>();

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool HasMore { get; set; }

    [Parameter]
    public bool AutoRefreshEnabled { get; set; }

    [Parameter]
    public int RefreshIntervalSeconds { get; set; }

    [Parameter]
    public IEnumerable<int> RefreshIntervals { get; set; } = Array.Empty<int>();

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback Refresh { get; set; }

    [Parameter]
    public EventCallback LoadMore { get; set; }

    [Parameter]
    public EventCallback<bool> AutoRefreshChanged { get; set; }

    [Parameter]
    public EventCallback<int> RefreshIntervalChanged { get; set; }

    [Parameter]
    public Func<SonosQueueItem, string>? FormatItem { get; set; }

    [Parameter]
    public string? SpeakerName { get; set; }

    private string RefreshSelectId { get; } = $"queueRefresh_{Guid.NewGuid():N}";

    private string QueueContextLabel => string.IsNullOrWhiteSpace(SpeakerName) ? "the active room" : SpeakerName!;

    private string QueueSubtitle => Items.Count > 0
        ? $"{Items.Count} item{(Items.Count == 1 ? string.Empty : "s")} ready for {QueueContextLabel}."
        : $"Live queue view for {QueueContextLabel}.";

    private bool AutoRefreshEnabledValue
    {
        get => AutoRefreshEnabled;
        set
        {
            if (value == AutoRefreshEnabled)
            {
                return;
            }

            _ = AutoRefreshChanged.InvokeAsync(value);
        }
    }

    private Task HandleIntervalChange(ChangeEventArgs args)
    {
        if (args.Value is string raw && int.TryParse(raw, out var seconds))
        {
            return RefreshIntervalChanged.InvokeAsync(seconds);
        }

        return Task.CompletedTask;
    }
}
