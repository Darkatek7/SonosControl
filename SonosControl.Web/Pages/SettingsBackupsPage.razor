@* Routed through AdministrationPage. *@
@using SonosControl.Web.Services
@attribute [Authorize(Roles = "admin,superadmin")]
@inject ConfiguredTimeZoneService AppTimeZone
@inject ISettingsBackupService Backups

<PageTitle>Settings Backups - Sonos Control</PageTitle>

<div class="backups-console-shell">
    <section class="backups-hero" aria-labelledby="backups-heading">
        <div class="backups-hero__copy">
            <span class="spotify-eyebrow">Recovery Point</span>
            <h1 id="backups-heading">Backups</h1>
            <p>Create versioned config snapshots, restore safely, and import JSON settings without leaving the admin console.</p>
        </div>
        <div class="backups-hero__metrics" aria-label="Backup summary">
            <div class="backups-stat">
                <span><Icon Name="backup" Size="16" /> Files</span>
                <strong>@_backups.Count</strong>
            </div>
            <div class="backups-stat">
                <span><Icon Name="clock" Size="16" /> Latest</span>
                <strong>@GetLatestBackupLabel()</strong>
            </div>
            <div class="backups-stat">
                <span><Icon Name="hard-drive" Size="16" /> Storage</span>
                <strong>@FormatBytes(_backups.Sum(backup => backup.Bytes))</strong>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") backups-alert" role="status">@_statusMessage</div>
    }

    <section class="backups-actions-panel">
        <button type="button" class="btn btn-outline-primary" @onclick="RefreshBackupsAsync" disabled="@_isBusy">
            <Icon Name="refresh" Size="16" /> Refresh
        </button>
        <button type="button" class="btn btn-primary" @onclick="CreateBackupAsync" disabled="@_isBusy">
            @if (_isBusy)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            else
            {
                <Icon Name="plus" Size="16" />
            }
            <span>Create Backup</span>
        </button>
    </section>

    <section class="backups-workspace">
        <article class="backups-panel backups-panel--wide">
            <div class="backups-panel__header">
                <div>
                    <span class="spotify-eyebrow">Archive</span>
                    <h2><Icon Name="backup" Size="18" /> Available Backups</h2>
                </div>
                <span class="backups-panel__count">@_backups.Count file(s)</span>
            </div>

            @if (_backups.Any())
            {
                <div class="backups-table-wrapper">
                    <table class="backups-table">
                        <thead>
                        <tr>
                            <th scope="col">File</th>
                            <th scope="col">Created</th>
                            <th scope="col">Size</th>
                            <th scope="col">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var backup in _backups)
                        {
                            <tr>
                                <td>
                                    <div class="backup-file-name">
                                        <span><Icon Name="file" Size="16" /></span>
                                        <strong>@backup.FileName</strong>
                                    </div>
                                </td>
                                <td class="backups-table__muted">@FormatCreated(backup.CreatedUtc)</td>
                                <td class="backups-table__muted">@FormatBytes(backup.Bytes)</td>
                                <td>
                                    <div class="backup-actions">
                                        <a class="btn btn-outline-secondary btn-sm backup-action-btn" href="@($"/api/settings/backups/{Uri.EscapeDataString(backup.FileName)}")">
                                            <Icon Name="file" Size="15" /> Download
                                        </a>
                                        <button type="button" class="btn btn-outline-success btn-sm backup-action-btn" @onclick="() => RequestRestoreBackup(backup)" disabled="@_isBusy">
                                            <Icon Name="refresh" Size="15" /> Restore
                                        </button>
                                        <button type="button" class="btn btn-outline-danger btn-sm backup-action-btn" @onclick="() => RequestDeleteBackup(backup)" disabled="@_isBusy">
                                            <Icon Name="trash" Size="15" /> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="backups-card-list">
                    @foreach (var backup in _backups)
                    {
                        <article class="backup-card">
                            <div class="backup-card__header">
                                <div class="backup-file-name">
                                    <span><Icon Name="file" Size="16" /></span>
                                    <strong>@backup.FileName</strong>
                                </div>
                                <span>@FormatBytes(backup.Bytes)</span>
                            </div>
                            <div class="backup-card__meta">@FormatCreated(backup.CreatedUtc)</div>
                            <div class="backup-actions">
                                <a class="btn btn-outline-secondary btn-sm backup-action-btn" href="@($"/api/settings/backups/{Uri.EscapeDataString(backup.FileName)}")">
                                    <Icon Name="file" Size="15" /> Download
                                </a>
                                <button type="button" class="btn btn-outline-success btn-sm backup-action-btn" @onclick="() => RequestRestoreBackup(backup)" disabled="@_isBusy">
                                    <Icon Name="refresh" Size="15" /> Restore
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm backup-action-btn" @onclick="() => RequestDeleteBackup(backup)" disabled="@_isBusy">
                                    <Icon Name="trash" Size="15" /> Delete
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="backups-empty-state">
                    <Icon Name="backup" Size="28" />
                    <strong>No backups found.</strong>
                    <span>Create a backup to capture the current config state.</span>
                </div>
            }
        </article>

        <article class="backups-panel">
            <div class="backups-panel__header">
                <div>
                    <span class="spotify-eyebrow">Import</span>
                    <h2><Icon Name="file" Size="18" /> Config JSON</h2>
                </div>
            </div>

            <p class="backups-panel__copy">Import overwrites current settings and automatically creates a versioned backup first.</p>

            <div class="backup-import-control">
                <InputFile id="settingsImportFile"
                           OnChange="OnImportFileSelected"
                           accept=".json,application/json"
                           class="backup-native-file"
                           style="position:absolute;inline-size:1px;block-size:1px;opacity:0;pointer-events:none;" />
                <label class="backup-file-button" for="settingsImportFile">
                    <Icon Name="file" Size="16" />
                    <span>Choose JSON</span>
                </label>
                <span class="backup-selected-file">@(!string.IsNullOrWhiteSpace(_selectedImportFileName) ? _selectedImportFileName : "No file selected")</span>
            </div>

            <button type="button" class="btn btn-warning backups-import-btn" @onclick="ImportSelectedFileAsync" disabled="@(_isBusy || _selectedImportFile is null)">
                <Icon Name="refresh" Size="16" /> Import Selected File
            </button>
        </article>
    </section>
</div>

<ConfirmDialog Visible="@(_pendingRestore is not null)"
               Title="Restore settings backup"
               Message="@GetRestoreMessage()"
               ConfirmLabel="Create safety backup and restore"
               OnConfirm="ConfirmRestoreBackupAsync"
               OnCancel="CancelBackupAction" />

<ConfirmDialog Visible="@(_pendingDelete is not null)"
               Title="Delete backup"
               Message="@($"Delete '{_pendingDelete?.FileName}'? This backup cannot be recovered.")"
               ConfirmLabel="Delete backup"
               Dangerous="true"
               OnConfirm="ConfirmDeleteBackupAsync"
               OnCancel="CancelBackupAction" />

@code {
    private readonly List<SettingsBackupInfo> _backups = new();
    private IBrowserFile? _selectedImportFile;
    private string? _selectedImportFileName;
    private bool _isBusy;
    private string? _statusMessage;
    private bool _statusIsError;
    private SettingsBackupInfo? _pendingRestore;
    private SettingsBackupInfo? _pendingDelete;

    protected override async Task OnInitializedAsync()
    {
        await RefreshBackupsAsync();
    }

    private Task RefreshBackupsAsync()
    {
        return RefreshBackupsAsyncInternal(manageBusy: true);
    }

    private async Task RefreshBackupsAsyncInternal(bool manageBusy)
    {
        if (manageBusy)
        {
            _isBusy = true;
        }

        try
        {
            _backups.Clear();
            _backups.AddRange(await Backups.ListAsync());
            ShowStatus("Backups refreshed.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Could not load backups: {ex.Message}", true);
        }
        finally
        {
            if (manageBusy)
            {
                _isBusy = false;
            }
        }
    }

    private async Task CreateBackupAsync()
    {
        _isBusy = true;
        try
        {
            var backup = await Backups.CreateAsync();
            if (backup is null)
            {
                throw new FileNotFoundException("config.json was not found.");
            }

            await RefreshBackupsAsyncInternal(manageBusy: false);
            ShowStatus($"Backup created: {backup.FileName}");
        }
        catch (Exception ex)
        {
            ShowStatus($"Backup creation failed: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void RequestRestoreBackup(SettingsBackupInfo backup)
    {
        _pendingRestore = backup;
        _pendingDelete = null;
    }

    private void RequestDeleteBackup(SettingsBackupInfo backup)
    {
        _pendingDelete = backup;
        _pendingRestore = null;
    }

    private void CancelBackupAction()
    {
        _pendingRestore = null;
        _pendingDelete = null;
    }

    private string GetRestoreMessage()
    {
        return _pendingRestore is null
            ? string.Empty
            : $"Restore '{_pendingRestore.FileName}' from {FormatCreated(_pendingRestore.CreatedUtc)}? The current configuration will first be saved as a new safety backup.";
    }

    private async Task ConfirmRestoreBackupAsync()
    {
        var backup = _pendingRestore;
        CancelBackupAction();
        if (backup is null)
        {
            return;
        }

        _isBusy = true;
        try
        {
            var restored = await Backups.RestoreAsync(backup.FileName);
            await RefreshBackupsAsyncInternal(manageBusy: false);
            ShowStatus($"Restored {backup.FileName}. Safety backup: {restored.SafetyBackup ?? "not required"}.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Restore failed: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ConfirmDeleteBackupAsync()
    {
        var backup = _pendingDelete;
        CancelBackupAction();
        if (backup is null)
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Backups.DeleteAsync(backup.FileName);
            await RefreshBackupsAsyncInternal(manageBusy: false);
            ShowStatus($"Deleted backup: {backup.FileName}");
        }
        catch (Exception ex)
        {
            ShowStatus($"Delete failed: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void OnImportFileSelected(InputFileChangeEventArgs args)
    {
        _selectedImportFile = args.GetMultipleFiles(1).FirstOrDefault();
        _selectedImportFileName = _selectedImportFile?.Name;
    }

    private async Task ImportSelectedFileAsync()
    {
        if (_selectedImportFile is null)
        {
            ShowStatus("Please choose a JSON file first.", true);
            return;
        }

        _isBusy = true;
        try
        {
            await using var stream = _selectedImportFile.OpenReadStream(maxAllowedSize: ISettingsBackupService.MaxImportBytes);
            await Backups.ImportAsync(_selectedImportFile.Name, stream, _selectedImportFile.Size);

            _selectedImportFile = null;
            _selectedImportFileName = null;
            await RefreshBackupsAsyncInternal(manageBusy: false);
            ShowStatus("Settings imported successfully.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Import failed: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024.0:F1} KB";
        }

        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private string FormatCreated(DateTime createdUtc) => AppTimeZone.Format(createdUtc);

    private string GetLatestBackupLabel()
    {
        var latest = _backups.FirstOrDefault();
        return latest is null ? "None" : FormatCreated(latest.CreatedUtc)[..5];
    }

    private void ShowStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

}
