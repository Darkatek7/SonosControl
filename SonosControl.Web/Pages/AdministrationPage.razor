@page "/administration"
@page "/administration/devices"
@page "/administration/settings"
@page "/administration/users"
@page "/administration/backups"
@page "/devices"
@page "/config"
@page "/admin/users"
@page "/settings-backups"
@using Microsoft.AspNetCore.Components.Routing
@using SonosControl.Web.Services
@attribute [Authorize(Roles = "admin,superadmin")]
@implements IDisposable
@inject NavigationManager Navigation
@inject AutomationRuntimeStatus RuntimeStatus

<PageTitle>Administration - SonosControl</PageTitle>

<div class="workspace-page administration-page" data-qa="administration-page">
    <header class="workspace-header">
        <div>
            <span class="workspace-eyebrow">Admin only</span>
            <h1>Administration</h1>
            <p>Manage devices, system defaults, users, and recovery points.</p>
        </div>
    </header>

    <WorkspaceTabs Items="AdministrationTabs"
                   ActiveKey="@_activeTab"
                   OnSelect="SelectTab"
                   AriaLabel="Administration sections"
                   IdPrefix="administration" />

    <section id="@($"administration-panel-{_activeTab}")"
             role="tabpanel"
             aria-labelledby="@($"administration-tab-{_activeTab}")"
             tabindex="0"
             class="workspace-tab-panel">
    @if (_activeTab == "settings")
    {
        var automation = RuntimeStatus.Snapshot;
        @if (automation.Phase == AutomationRuntimePhase.Failed)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Automation migration failed.</strong> @automation.Error Time-based playback remains disabled; the original configuration was retained.
            </div>
        }
        else if (automation.Warnings.Count > 0)
        {
            <div class="alert alert-warning" role="status">Automation is running with @automation.Warnings.Count configuration warning(s). Review Automation for details.</div>
        }
        <ConfigPage />
    }
    else if (_activeTab == "users")
    {
        <UserManagement />
    }
    else if (_activeTab == "backups")
    {
        <SettingsBackupsPage />
    }
    else
    {
        <DevicesPage />
    }
    </section>
</div>

@code {
    private string _activeTab = "devices";
    private bool _redirectedAlias;
    private static readonly IReadOnlyList<WorkspaceTabItem> AdministrationTabs =
    [
        new("devices", "Devices"),
        new("settings", "System settings"),
        new("users", "Users"),
        new("backups", "Backups")
    ];

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override void OnParametersSet()
    {
        _activeTab = ResolveTab(Navigation.Uri);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || _redirectedAlias) return;
        var route = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
        var target = route switch
        {
            "administration" => "/administration/devices",
            "devices" => "/administration/devices",
            "config" => "/administration/settings",
            "admin/users" => "/administration/users",
            "settings-backups" => "/administration/backups",
            _ => null
        };
        if (target is not null)
        {
            _redirectedAlias = true;
            Navigation.NavigateTo(target, replace: true);
        }
    }

    private void SelectTab(string tab)
    {
        _activeTab = tab;
        Navigation.NavigateTo($"/administration/{tab}");
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var tab = ResolveTab(args.Location);
        if (_activeTab == tab) return;

        _ = InvokeAsync(() =>
        {
            _activeTab = tab;
            StateHasChanged();
        });
    }

    private string ResolveTab(string location)
    {
        var route = Navigation.ToBaseRelativePath(location).Split('?', '#')[0].Trim('/');
        return route switch
        {
            "administration/settings" or "config" => "settings",
            "administration/users" or "admin/users" => "users",
            "administration/backups" or "settings-backups" => "backups",
            _ => "devices"
        };
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
