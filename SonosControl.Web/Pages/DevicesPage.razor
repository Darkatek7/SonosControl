@* Routed through AdministrationPage. *@
@using SonosControl.Web.Services
@inject ISonosDeviceDiscoveryService DiscoveryService
@inject IDeviceHealthSnapshotStore DeviceHealthSnapshotStore
@inject ConfiguredTimeZoneService AppTimeZone
@attribute [Authorize(Roles = "admin,superadmin")]

<PageTitle>Devices - Sonos Control</PageTitle>

<div class="devices-console-shell">
    <section class="devices-hero" aria-labelledby="devices-heading">
        <div class="devices-hero__copy">
            <span class="spotify-eyebrow">Administration</span>
            <h1 id="devices-heading">Devices</h1>
            <p>Discover speakers, review health, and manage names, addresses, and startup volume.</p>
        </div>
        <div class="devices-hero__actions">
            <div class="devices-stat">
                <span><Icon Name="speaker" Size="16" /> Configured</span>
                <strong>@(_settings?.Speakers?.Count ?? 0)</strong>
            </div>
            <div class="devices-stat">
                <span><Icon Name="check" Size="16" /> Online</span>
                <strong>@GetOnlineSpeakerCount()</strong>
            </div>
            <button type="button" class="btn btn-outline-primary" @onclick="RefreshHealth"><Icon Name="refresh" Size="16" /> Health</button>
            <button type="button" class="btn btn-primary" @onclick="RunDiscovery" disabled="@_isDiscovering">
                @if (_isDiscovering)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>Scanning...</span>
                }
                else
                {
                    <Icon Name="search" Size="16" />
                    <span>Discover</span>
                }
            </button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") devices-alert" role="status">@_statusMessage</div>
    }

    @if (_settings is null)
    {
        <section class="devices-panel devices-empty-state">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <strong>Loading devices...</strong>
        </section>
    }
    else
    {
        <section class="devices-health-strip" aria-label="Device health summary">
            <div class="devices-health-tile is-online">
                <span>Online</span>
                <strong>@GetOnlineSpeakerCount()</strong>
            </div>
            <div class="devices-health-tile is-offline">
                <span>Offline</span>
                <strong>@GetOfflineSpeakerCount()</strong>
            </div>
            <div class="devices-health-tile is-unknown">
                <span>Unknown</span>
                <strong>@GetUnknownSpeakerCount()</strong>
            </div>
            <div class="devices-health-tile">
                <span>Discovered</span>
                <strong>@_discoveredSpeakers.Count</strong>
            </div>
        </section>

        <section class="devices-workspace">
            <article class="devices-panel">
                <div class="devices-panel__header">
                    <div>
                        <span class="spotify-eyebrow">Inventory</span>
                        <h2><Icon Name="speaker" Size="18" /> Configured Speakers</h2>
                    </div>
                </div>

                @if (_settings.Speakers.Any())
                {
                    <div class="devices-list">
                        @foreach (var speaker in _settings.Speakers.OrderBy(s => s.Name))
                        {
                            var health = _healthByIp.TryGetValue(speaker.IpAddress, out var status) ? status : null;
                            <article class="device-card">
                                <div class="device-card__icon @GetHealthClass(health)">
                                    <Icon Name="speaker" Size="18" />
                                </div>
                                <div class="device-card__body">
                                    <strong>@speaker.Name</strong>
                                    <span>@speaker.IpAddress</span>
                                    @if (!string.IsNullOrWhiteSpace(health?.LastError))
                                    {
                                        <small>@health.LastError</small>
                                    }
                                </div>
                                <div class="device-card__status">
                                    <span class="device-status-pill @GetHealthClass(health)">@GetHealthLabel(health)</span>
                                    <small>@FormatLastSeen(health)</small>
                                </div>
                                <div class="device-card__settings">
                                    <label>
                                        <span>Name</span>
                                        <input class="form-control form-control-sm" value="@speaker.Name" @onchange="e => UpdateSpeakerNameAsync(speaker, e.Value)" aria-label="@($"Name for {speaker.Name}")" />
                                    </label>
                                    <label>
                                        <span>Startup volume</span>
                                        <input class="form-control form-control-sm" type="number" min="0" max="100" value="@speaker.StartupVolume" @onchange="e => UpdateStartupVolumeAsync(speaker, e.Value)" placeholder="@_settings.Volume" aria-label="@($"Startup volume for {speaker.Name}")" />
                                    </label>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RequestRemoveSpeaker(speaker)" aria-label="@($"Remove {speaker.Name}")"><Icon Name="trash" Size="15" /> Remove</button>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="devices-empty-state">
                        <Icon Name="speaker" Size="24" />
                        <strong>No speakers configured.</strong>
                        <span>Run discovery to find Sonos devices and import them into config.</span>
                    </div>
                }
            </article>

            <article class="devices-panel">
                <div class="devices-panel__header">
                    <div>
                        <span class="spotify-eyebrow">Discovery</span>
                        <h2><Icon Name="search" Size="18" /> Discovery Results</h2>
                    </div>
                    @if (_discoveredSpeakers.Any())
                    {
                        <button type="button" class="btn btn-outline-success btn-sm devices-import-all" @onclick="ImportAllDiscovered">
                            <Icon Name="plus" Size="15" /> Import All
                        </button>
                    }
                </div>

                @if (_discoveredSpeakers.Any())
                {
                    <div class="devices-table-wrapper">
                        <table class="table table-sm align-middle devices-table">
                            <thead>
                            <tr>
                                <th>Name</th>
                                <th>IP</th>
                                <th>UUID</th>
                                <th class="text-end">Import</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var speaker in _discoveredSpeakers.OrderBy(s => s.Name))
                            {
                                var exists = _settings.Speakers.Any(s => string.Equals(s.IpAddress, speaker.IpAddress, StringComparison.OrdinalIgnoreCase));
                                <tr>
                                    <td>@speaker.Name</td>
                                    <td>@speaker.IpAddress</td>
                                    <td>@(!string.IsNullOrWhiteSpace(speaker.Uuid) ? speaker.Uuid : "-")</td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-outline-primary btn-sm"
                                                @onclick="() => ImportSpeaker(speaker)"
                                                disabled="@exists">
                                            @(exists ? "Imported" : "Import")
                                        </button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="devices-empty-state">
                        <Icon Name="search" Size="24" />
                        <strong>No discovery results yet.</strong>
                        <span>Start a scan to discover speakers on the local network.</span>
                    </div>
                }
            </article>

            <article class="devices-panel devices-manual-panel">
                <div class="devices-panel__header">
                    <div>
                        <span class="spotify-eyebrow">Manual setup</span>
                        <h2><Icon Name="plus" Size="18" /> Add speaker</h2>
                    </div>
                </div>
                <div class="devices-manual-form">
                    <div>
                        <label for="manual-speaker-name" class="form-label">Name</label>
                        <input id="manual-speaker-name" class="form-control" @bind="_manualName" placeholder="Living Room" />
                    </div>
                    <div>
                        <label for="manual-speaker-ip" class="form-label">IPv4 address</label>
                        <input id="manual-speaker-ip" class="form-control" @bind="_manualIp" inputmode="decimal" placeholder="192.168.1.50" />
                    </div>
                    <div>
                        <label for="manual-speaker-volume" class="form-label">Startup volume</label>
                        <input id="manual-speaker-volume" class="form-control" type="number" min="0" max="100" @bind="_manualStartupVolume" />
                    </div>
                    <button type="button" class="btn btn-primary" @onclick="AddManualSpeakerAsync"><Icon Name="plus" Size="15" /> Add speaker</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_manualError))
                {
                    <div class="alert alert-danger mt-3 mb-0" role="alert">@_manualError</div>
                }
            </article>
        </section>
    }
</div>

@if (_pendingRemoval is not null)
{
    <div class="app-dialog-backdrop" @onclick="CancelRemoveSpeaker">
        <section class="app-dialog app-dialog--confirm" role="alertdialog" aria-modal="true" aria-labelledby="remove-device-title" aria-describedby="remove-device-copy" @onclick:stopPropagation="true">
            <header class="app-dialog__header"><h2 id="remove-device-title">Remove speaker?</h2></header>
            <div class="app-dialog__body"><p id="remove-device-copy">“@_pendingRemoval.Name” (@_pendingRemoval.IpAddress) will be removed from SonosControl.</p></div>
            <footer class="app-dialog__actions">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelRemoveSpeaker">Cancel</button>
                <button type="button" class="btn btn-danger" @onclick="RemoveSpeakerAsync">Remove</button>
            </footer>
        </section>
    </div>
}

@code {
    private SonosSettings? _settings;
    private List<SonosSpeaker> _discoveredSpeakers = new();
    private Dictionary<string, DeviceHealthStatus> _healthByIp = new(StringComparer.OrdinalIgnoreCase);
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isDiscovering;
    private string _manualName = string.Empty;
    private string _manualIp = string.Empty;
    private int? _manualStartupVolume;
    private string? _manualError;
    private SonosSpeaker? _pendingRemoval;

    private int GetOnlineSpeakerCount() => _settings?.Speakers?.Count(s => _healthByIp.TryGetValue(s.IpAddress, out var health) && health.IsOnline) ?? 0;

    private int GetOfflineSpeakerCount() => _settings?.Speakers?.Count(s => _healthByIp.TryGetValue(s.IpAddress, out var health) && !health.IsOnline) ?? 0;

    private int GetUnknownSpeakerCount() => _settings?.Speakers?.Count(s => !_healthByIp.ContainsKey(s.IpAddress)) ?? 0;

    private static string GetHealthLabel(DeviceHealthStatus? health)
    {
        if (health is null)
        {
            return "Unknown";
        }

        return health.IsOnline ? "Online" : "Offline";
    }

    private static string GetHealthClass(DeviceHealthStatus? health)
    {
        if (health is null)
        {
            return "is-unknown";
        }

        return health.IsOnline ? "is-online" : "is-offline";
    }

    private string FormatLastSeen(DeviceHealthStatus? health)
    {
        return health is null ? "No snapshot" : AppTimeZone.Format(health.LastSeenUtc);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        RefreshHealth();
    }

    private async Task LoadSettingsAsync()
    {
        _settings = await _uow.ISettingsRepo.GetSettings() ?? new SonosSettings();
        _settings.Speakers ??= new();
    }

    private async Task RunDiscovery()
    {
        _isDiscovering = true;
        try
        {
            _discoveredSpeakers = (await DiscoveryService.DiscoverAsync(TimeSpan.FromSeconds(5))).ToList();
            ShowStatus($"Discovery complete: {_discoveredSpeakers.Count} speaker(s) found.");
        }
        catch (Exception ex)
        {
            ShowStatus($"Device discovery failed: {ex.Message}", true);
        }
        finally
        {
            _isDiscovering = false;
        }
    }

    private async Task ImportSpeaker(SonosSpeaker speaker)
    {
        if (_settings is null)
        {
            return;
        }

        var exists = _settings.Speakers.Any(s => string.Equals(s.IpAddress, speaker.IpAddress, StringComparison.OrdinalIgnoreCase));
        if (exists)
        {
            return;
        }

        _settings.Speakers.Add(new SonosSpeaker
        {
            Name = speaker.Name,
            IpAddress = speaker.IpAddress,
            Uuid = speaker.Uuid
        });

        await _uow.ISettingsRepo.WriteSettings(_settings);
        ShowStatus($"Imported {speaker.Name}.");
    }

    private async Task ImportAllDiscovered()
    {
        if (_settings is null)
        {
            return;
        }

        var imported = 0;
        foreach (var speaker in _discoveredSpeakers)
        {
            if (_settings.Speakers.Any(s => string.Equals(s.IpAddress, speaker.IpAddress, StringComparison.OrdinalIgnoreCase)))
            {
                continue;
            }

            _settings.Speakers.Add(new SonosSpeaker
            {
                Name = speaker.Name,
                IpAddress = speaker.IpAddress,
                Uuid = speaker.Uuid
            });
            imported++;
        }

        if (imported > 0)
        {
            await _uow.ISettingsRepo.WriteSettings(_settings);
        }

        ShowStatus(imported > 0 ? $"Imported {imported} speaker(s)." : "No new speakers to import.");
    }

    private async Task UpdateSpeakerNameAsync(SonosSpeaker speaker, object? value)
    {
        if (_settings is null) return;
        var name = value?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            ShowStatus("Speaker name cannot be empty.", true);
            return;
        }
        speaker.Name = name;
        await _uow.ISettingsRepo.WriteSettings(_settings);
        ShowStatus($"Updated {speaker.Name}.");
    }

    private async Task UpdateStartupVolumeAsync(SonosSpeaker speaker, object? value)
    {
        if (_settings is null) return;
        speaker.StartupVolume = int.TryParse(value?.ToString(), out var parsed) ? Math.Clamp(parsed, 0, 100) : null;
        await _uow.ISettingsRepo.WriteSettings(_settings);
        ShowStatus($"Startup volume updated for {speaker.Name}.");
    }

    private async Task AddManualSpeakerAsync()
    {
        if (_settings is null) return;
        _manualError = null;
        if (string.IsNullOrWhiteSpace(_manualName) || !IPAddress.TryParse(_manualIp, out var address) || address.AddressFamily != System.Net.Sockets.AddressFamily.InterNetwork || IPAddress.IsLoopback(address) || address.Equals(IPAddress.Any))
        {
            _manualError = "Enter a name and a valid, non-loopback IPv4 address.";
            return;
        }
        if (_settings.Speakers.Any(speaker => string.Equals(speaker.IpAddress, _manualIp.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            _manualError = "A speaker with that address already exists.";
            return;
        }
        var speaker = new SonosSpeaker { Name = _manualName.Trim(), IpAddress = _manualIp.Trim(), StartupVolume = _manualStartupVolume.HasValue ? Math.Clamp(_manualStartupVolume.Value, 0, 100) : null };
        _settings.Speakers.Add(speaker);
        await _uow.ISettingsRepo.WriteSettings(_settings);
        _manualName = string.Empty;
        _manualIp = string.Empty;
        _manualStartupVolume = null;
        ShowStatus($"Added {speaker.Name}.");
    }

    private void RequestRemoveSpeaker(SonosSpeaker speaker) => _pendingRemoval = speaker;
    private void CancelRemoveSpeaker() => _pendingRemoval = null;

    private async Task RemoveSpeakerAsync()
    {
        if (_settings is null || _pendingRemoval is null) return;
        var name = _pendingRemoval.Name;
        _settings.Speakers.Remove(_pendingRemoval);
        await _uow.ISettingsRepo.WriteSettings(_settings);
        _pendingRemoval = null;
        ShowStatus($"Removed {name}.");
    }

    private void RefreshHealth()
    {
        _healthByIp = DeviceHealthSnapshotStore.GetSnapshot()
            .GroupBy(s => s.SpeakerIp, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);
    }

    private void ShowStatus(string message, bool isError = false)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }
}
